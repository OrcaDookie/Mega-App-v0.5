/* ═══════════════════════════════════════
   MOBILE + SCROLLING + QOL
═══════════════════════════════════════ */

/* Global scrolling */
*, *::before, *::after { box-sizing: border-box; }
html, body { height: 100%; overflow: hidden; }
.shell { display: flex; height: 100vh; overflow: hidden; }
.panel{flex:1;overflow-y:auto;flex-direction:column;height:100%}
.special-msgs { overflow-y: auto; }
.special-panel { display: flex; flex-direction: column; height: 100%; overflow: hidden; }

/* Smooth scrolling everywhere */
* { scrollbar-width: thin; scrollbar-color: var(--bdr2) transparent; }
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--bdr2); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }

/* Version badge */
.version-badge {
  font-size: 9px;
  color: var(--hint);
  padding: 2px 6px;
  border-radius: 10px;
  background: var(--surf2);
  border: 1px solid var(--bdr);
  letter-spacing: .04em;
  user-select: none;
  white-space: nowrap;
}

/* Mobile styles */
@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: 60px;
    width: 100% !important;
    flex-direction: row !important;
    align-items: center;
    justify-content: space-around;
    padding: 0 4px;
    border-top: 1px solid var(--bdr);
    border-right: none;
    overflow-x: auto;
    overflow-y: hidden;
    z-index: 100;
    gap: 0 !important;
  }
  .sidebar .nav-sep { display: none; }
  .nav-logo { font-size: 20px !important; width: 36px !important; height: 36px !important; }
  .nav-btn { width: 40px !important; height: 40px !important; flex-shrink: 0; }
  .nav-btn .tip { display: none !important; }
  .shell { flex-direction: column; }
  .panel.active{height:calc(100vh - 60px)}
  .special-panel { height: calc(100vh - 60px); }
  .calc-wrap { padding: 8px !important; }
  .custom-wrap { padding: 8px !important; }
  .wg { grid-template-columns: 1fr 1fr !important; }
  .special-topbar { flex-wrap: wrap; gap: 6px; padding: 10px !important; }
  .special-tag { display: none; }
}

@media (max-width: 480px) {
  .wg { grid-template-columns: 1fr !important; }
  .special-topbar .special-tag, .special-topbar button:last-child { display: none; }
}

/* Windows-style breadcrumb nav */
.breadcrumb-nav {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: var(--sb);
  border-bottom: 1px solid var(--bdr);
  font-size: 12px;
  color: var(--muted);
  flex-shrink: 0;
  overflow-x: auto;
  white-space: nowrap;
}
.breadcrumb-btn {
  padding: 3px 8px;
  border-radius: 5px;
  background: transparent;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: 11px;
  font-family: 'Outfit', sans-serif;
  transition: all .15s;
}
.breadcrumb-btn:hover { background: var(--surf2); color: var(--txt); }
.breadcrumb-sep { color: var(--hint); font-size: 10px; }

/* Gradient accent support */
.accent-gradient { background: var(--accent-gradient, var(--accent)); }

/* Syntax error popup */
.calc-error-popup {
  position: absolute;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(239,68,68,.15);
  border: 1px solid rgba(239,68,68,.3);
  color: #ff6b6b;
  padding: 8px 16px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 500;
  pointer-events: none;
  opacity: 0;
  transition: opacity .2s;
  white-space: nowrap;
  z-index: 50;
}
.calc-error-popup.show { opacity: 1; }

/* LaTeX rendering */
.katex-display { overflow-x: auto; overflow-y: hidden; }

/* AI response avatar bubble */
.ai-response-avatar {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  box-shadow: 0 4px 20px rgba(0,0,0,.4);
  z-index: 200;
  opacity: 0;
  transform: scale(0.6);
  transition: all .25s cubic-bezier(.34,1.56,.64,1);
  cursor: pointer;
  pointer-events: none;
}
.ai-response-avatar.show {
  opacity: 1;
  transform: scale(1);
  pointer-events: all;
}

</style>
