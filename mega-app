  // AI system prompt language suffix
  window._langSuffix = s.sysLangSuffix;
  if(typeof trackLang==='function') trackLang();

  // Swap jokes for language
  if(JOKES_LANG[code]){
    var jl=(typeof JOKES_LANG!=='undefined'&&JOKES_LANG[code])||[];
    jokeIdx=Math.floor(Math.random()*(jl||[]).length);
    const jb=document.getElementById('joke-box');
    const jt=document.getElementById('joke-text');
    if(jt) jt.textContent=(jl||[])[ jokeIdx];
    if(jb){jb.onclick=()=>{jokeIdx=(jokeIdx+1)%(jl||[]).length;const jt2=document.getElementById('joke-text');if(jt2)jt2.textContent=(jl||[])[ jokeIdx];};}
