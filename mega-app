function simulateRun(code,lang){
  addOutput(`▶ Running ${LANG_META[lang].label}...`,'out-info');
  addOutput('');

  // extract print/console statements and simulate output
  const lines=code.split('\n');
  let outputs=[];

  if(lang==='python'){
    lines.forEach(line=>{
      const m=line.match(/print\((.+)\)/);
      if(m){
        try{
          let expr=m[1].replace(/f"([^"]*)"/g,(_,s)=>s.replace(/\{([^}]+)\}/g,(_,e)=>{try{return String(eval(e))}catch{return e}}));
          expr=expr.replace(/^["'](.*)["']$/,'$1');
          outputs.push(expr);
        }catch(e){outputs.push(m[1])}
      }
    });
  } else if(['java','c','cplus','cpp'].includes(lang)){
    lines.forEach(line=>{
      const m=line.match(/(?:printf|println|cout\s*<<)\s*["(](.+?)[")\n]/);
      if(m){let s=m[1].replace(/\\n/g,'\n').replace(/^["']|["']$/g,'');outputs.push(s)}
    });
  } else if(lang==='csharp'){
    lines.forEach(line=>{
      const m=line.match(/Console\.(?:Write|WriteLine)\((.+)\)/);
      if(m){let s=m[1].replace(/^[$]?"(.*)"$/,'$1').replace(/\\n/g,'\n');outputs.push(s)}
    });
  } else if(lang==='lua'){
    lines.forEach(line=>{
      const m=line.match(/(?:print|io\.write)\((.+)\)/);
      if(m){let s=m[1].replace(/^["']|["']$/g,'').replace(/\.\./g,' ');outputs.push(s)}
    });
  }

  if((outputs||[]).length>0){
    outputs.forEach(o=>addOutput(o));
    addOutput('');
    addOutput('✓ Simulated execution complete','out-success');
  } else {
    addOutput('(No print statements found to simulate)','out-warn');
    addOutput('Tip: Add print() / printf() / Console.WriteLine() statements','out-info');
  }

  addOutput('');
  addOutput(`ℹ️ Full ${LANG_META[lang].label} execution requires a server-side runtime.`,'out-info');
}


