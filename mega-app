function runJS(code){
  const logs=[];
  const fakeConsole={
    log:(...a)=>logs.push({t:'log',v:a.map(x=>typeof x==='object'?JSON.stringify(x,null,2):String(x)).join(' ')}),
    error:(...a)=>logs.push({t:'error',v:a.join(' ')}),
    warn:(...a)=>logs.push({t:'warn',v:a.join(' ')}),
    info:(...a)=>logs.push({t:'info',v:a.join(' ')}),
  };
  try{
    const fn=new Function('console',code);
    fn(fakeConsole);
    logs.forEach(l=>{
      const cls=l.t==='error'?'out-error':l.t==='warn'?'out-warn':l.t==='info'?'out-info':'';
      addOutput(l.v,cls);
    });
    if(!(logs&&logs.length))addOutput('✓ Code ran (no output)','out-success');
  }catch(e){addOutput('❌ '+e.message,'out-error')}

  // also run async
  try{
    const realConsole=window.console;
    const origLog=realConsole.log;
    realConsole.log=(...a)=>{addOutput(a.map(x=>typeof x==='object'?JSON.stringify(x,null,2):String(x)).join(' '));origLog(...a)};
    const asyncFn=new Function('console',`return (async()=>{${code}})()`);
    asyncFn(window.console).catch(e=>addOutput('❌ '+e.message,'out-error')).finally(()=>realConsole.log=origLog);
  }catch(e){}
}

