function convertTemp(from,val){
  const v=parseFloat(val);if(isNaN(v))return;
  let c2,f,k;
  if(from==='C'){c2=v;f=v*9/5+32;k=v+273.15;}
  else if(from==='F'){c2=(v-32)*5/9;f=v;k=c2+273.15;}
  else{c2=v-273.15;f=c2*9/5+32;k=v;}
  if(from!=='C'){const el=document.getElementById('temp-c');if(el)el.value=+c2.toFixed(4);}
  if(from!=='F'){const el=document.getElementById('temp-f');if(el)el.value=+f.toFixed(4);}
  if(from!=='K'){const el=document.getElementById('temp-k');if(el)el.value=+k.toFixed(4);}
}
function doUnitConvert(){
  const val=parseFloat(document.getElementById('unit-val')?.value||0);
  const from=document.getElementById('unit-from')?.value;
  const units=UNIT_CATS[curUnitCat];if(!units)return;
  const base=val/units[from];
  const res=document.getElementById('unit-results');if(!res)return;
  res.innerHTML=Object.entries(units).filter(([k])=>k!==from).map(([k,factor])=>{
    const converted=base*factor;
    const display=Math.abs(converted)>1e6||Math.abs(converted)<1e-4?converted.toExponential(4):+converted.toPrecision(6);
    return `<div style="display:flex;justify-content:space-between;padding:6px 10px;background:var(--surf2);border-radius:7px;font-size:13px"><span style="color:var(--muted)">${k}</span><span style="color:var(--txt);font-weight:600;font-family:monospace">${display}</span></div>`;
  }).join('');
}

