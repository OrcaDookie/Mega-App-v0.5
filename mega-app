function renderAchievements(){
  const unlocked = getUnlocked();
  const stats = getAchStats();

  // Update stat numbers
  const sv = (id,v) => { const el=document.getElementById(id); if(el) el.textContent=v; };
  sv('stat-messages', stats.messages.toLocaleString());
  sv('stat-chats', stats.chats.toLocaleString());
  sv('stat-ais', (stats.aisUsed||[]).length);
  sv('stat-unlocked', (unlocked||[]).length+'/'+(ACHIEVEMENTS||[]).length);
  sv('ach-summary', (unlocked||[]).length+' of '+(ACHIEVEMENTS||[]).length+' achievements unlocked');

  // Group by category
  const cats = {};
  ACHIEVEMENTS.forEach(a => {
    if(!cats[a.cat]) cats[a.cat]=[];
    cats[a.cat].push(a);
  });

  const list = document.getElementById('ach-list');
  if(!list) return;
  list.innerHTML = '';

  Object.entries(cats).forEach(([cat, achs]) => {
    const title = document.createElement('div');
    title.className = 'ach-section-title';
    const catUnlocked = (achs||[]).filter(function(a){return (unlocked||[]).includes(a.id);}).length;
    title.textContent = cat + ' ('+catUnlocked+'/'+(achs||[]).length+')';
    list.appendChild(title);

    const grid = document.createElement('div');
    grid.className = 'ach-grid';

    achs.forEach(a => {
      const isUnlocked = unlocked.includes(a.id);
      const card = document.createElement('div');
      card.className = 'ach-card ' + (isUnlocked ? 'unlocked' : 'locked');

      let progressHTML = '';
      if(!isUnlocked && a.req.type==='messages'){
        const pct = Math.min(100, Math.round((stats.messages/a.req.n)*100));
        progressHTML = `<div class="ach-progress"><div class="ach-progress-bar" style="width:${pct}%"></div></div><div class="ach-progress-label">${stats.messages.toLocaleString()} / ${a.req.n.toLocaleString()}</div>`;
      }
      if(!isUnlocked && a.req.type==='chats'){
        const pct = Math.min(100, Math.round((stats.chats/a.req.n)*100));
        progressHTML = `<div class="ach-progress"><div class="ach-progress-bar" style="width:${pct}%"></div></div><div class="ach-progress-label">${stats.chats} / ${a.req.n}</div>`;
      }

      card.innerHTML = `
        <div class="ach-icon">${isUnlocked ? a.icon : '🔒'}</div>
        <div class="ach-name">${isUnlocked ? a.name : (a.cat==='Secrets' ? '???' : a.name)}</div>
        <div class="ach-desc">${isUnlocked ? a.desc : (a.cat==='Secrets' ? 'Hidden achievement — keep exploring!' : a.desc)}</div>
        ${progressHTML}
        ${isUnlocked ? '<div class="ach-unlocked-tag">✓ Unlocked</div>' : ''}
      `;
      grid.appendChild(card);
    });
    list.appendChild(grid);
  });
}


