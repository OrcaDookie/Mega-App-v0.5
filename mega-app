const LOGIN_EMOJIS=['😊','😎','🤩','👑','🦊','🐱','🤖','👾','🔥','⚡','🌟','🚀','💎','🌈','🧠','🎯','🦄','🐉','🎮','🎸','🌍','🌙'];
let loginSelectedAvatar='😊';let sessionToken=localStorage.getItem('mega-token')||'';

async function api(path,body=null,method=null){
  const opts={method:method||(body?'POST':'GET'),headers:{'Content-Type':'application/json','X-Session-Token':sessionToken}};
  if(body)opts.body=JSON.stringify(body);
  try{const r=await fetch(path,opts);return r.json();}catch(e){return {error:e.message};}
}

function loginShowTab(tab){
  const isIn=tab==='in';
  const lti=document.getElementById('ltab-in');const ltu=document.getElementById('ltab-up');
  const lfi=document.getElementById('lform-in');const lfu=document.getElementById('lform-up');
  if(lti)lti.classList.toggle('active',isIn);
  if(ltu)ltu.classList.toggle('active',!isIn);
  if(lfi)(lfi||{style:{}}).style.display=isIn?'block':'none';
  if(lfu)(lfu||{style:{}}).style.display=isIn?'none':'block';
}

function loginTogglePw(id,btn){
  const inp=document.getElementById(id);if(!inp)return;
  inp.type=inp.type==='password'?'text':'password';
  btn.textContent=inp.type==='password'?'👁':'🙈';
