function loginCopyPw(id){
  const v=document.getElementById(id)?.value;if(!v)return;
  navigator.clipboard.writeText(v).then(()=>{const b=event.target;b.textContent='✅';setTimeout(()=>b.textContent='📋',1400);});
}

function showLoginErr(id,msg){
  const el=document.getElementById(id);if(!el)return;
  el.textContent=msg;el.style.display='block';setTimeout(()=>el.style.display='none',4000);
}

async function loginDoSignIn(){
  const username=(document.getElementById('li-user')?.value||'').trim();
  const password=document.getElementById('li-pass')?.value||'';
  if(!username||!password){showLoginErr('li-err','Fill in all fields!');return;}
  const btn=document.querySelector('#lform-in .login-submit');
  if(btn){btn.textContent='Signing in...';btn.disabled=true;}
  const res=await api('/api/login',{username,password});
  if(btn){btn.textContent='Sign in →';btn.disabled=false;}
  if(res.token)loginComplete(res.token,res.user);
  else showLoginErr('li-err',res.error||'Wrong username or password');
}

async function loginDoSignUp(){
  const username=(document.getElementById('lu-user')?.value||'').trim();
  const email=(document.getElementById('lu-email')?.value||'').trim();
  const password=document.getElementById('lu-pass')?.value||'';
  if(!username||!password){showLoginErr('lu-err','Username and password required!');return;}
  const btn=document.querySelector('#lform-up .login-submit');
  if(btn){btn.textContent='Creating...';btn.disabled=true;}
  const res=await api('/api/signup',{username,email,password,avatar:loginSelectedAvatar});
  if(btn){btn.textContent='Create account →';btn.disabled=false;}
  if(res.token)loginComplete(res.token,res.user);
  else showLoginErr('lu-err',res.error||'Sign up failed');
}

function loginAsGuest(){
  currentUser={id:'guest',username:'Guest',avatar:'👤',provider:'guest'};
  applyUserToUI(currentUser);
  (document.getElementById('login-overlay')||{style:{}}).style.display='none';
  (document.getElementById('chat-setup')||{style:{}}).style.display='flex';
}

function loginComplete(token,user){
  sessionToken=token;currentUser=user;
  localStorage.setItem('mega-token',token);
  applyUserToUI(user);
  (document.getElementById('login-overlay')||{style:{}}).style.display='none';
  (document.getElementById('chat-setup')||{style:{}}).style.display='flex';
}

function applyUserToUI(user){
  if(!user)return;
  ['sidebar-username','acct-name'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=user.username||'';});
}

async function loginCheckSession(){
  if(sessionToken){
    const res=await api('/api/me');
    if(res.user){
      currentUser=res.user;applyUserToUI(res.user);
      (document.getElementById('login-overlay')||{style:{}}).style.display='none';
      (document.getElementById('chat-setup')||{style:{}}).style.display='flex';
      return;
    }
    localStorage.removeItem('mega-token');sessionToken='';
  }
  (document.getElementById('login-overlay')||{style:{}}).style.display='flex';
  initLoginAvatarGrid();
}

async function signOut(){
  if(sessionToken)await api('/api/logout',{});
  sessionToken='';currentUser=null;
  localStorage.removeItem('mega-token');
  (document.getElementById('login-overlay')||{style:{}}).style.display='flex';
  (document.getElementById('chat-setup')||{style:{}}).style.display='none';
  initLoginAvatarGrid();
}

function initLoginAvatarGrid(){
  const grid=document.getElementById('login-av-grid');if(!grid)return;
  grid.innerHTML=LOGIN_EMOJIS.map((e,i)=>
    `<div onclick="selectLoginEmoji('${e}',this)" style="font-size:20px;text-align:center;cursor:pointer;padding:4px;border-radius:7px;border:2px solid ${i===0?'var(--accent)':'transparent'};transition:all .15s">${e}</div>`
  ).join('');
}

function selectLoginEmoji(emoji,el){
  loginSelectedAvatar=emoji;
  document.querySelectorAll('#login-av-grid div').forEach(d=>d.style.borderColor='transparent');
  if(el)el.style.borderColor='var(--accent)';
}



