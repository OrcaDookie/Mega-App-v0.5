function applyProfilePicture(){
  // Export canvas as image and apply everywhere
  const canvas = document.getElementById('pfp-canvas');
  if(!canvas)return;
  const dataURL = canvas.toDataURL('image/png');

  const profile = safeLS('mega-profile-custom', {});
  profile.pfp = dataURL;
  profile.pfpState = {...pfpState};
  localStorage.setItem('mega-profile-custom', JSON.stringify(profile));

  applyPfpEverywhere(dataURL, pfpState.shape);

  const btn=event.target;
  btn.textContent='Applied! ✓';
  setTimeout(()=>btn.textContent='Apply profile picture',1500);
