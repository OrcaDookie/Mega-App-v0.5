async function callSpecialOllama(which){
  showSpecialTyping(which);
  const system=(SPECIAL_SYSTEMS[which]||"")+(window._langSuffix||'');
  const accentCol=(SPECIAL_COLORS[which]||"var(--accent)")||'var(--accent)';
  // Get model from selector or fallback
  const sel=document.getElementById('model-sel');
  let model='mistral';
  if(sel&&sel.value)model=sel.value;

  try{
    const res=await fetch('/ollama/api/chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:model,
        messages:[
          {role:'system',content:system},
          ...spMsgs[which]
        ],
        stream:true  // ← stream tokens as they arrive
      })
    });
    if(!res.ok)throw new Error('HTTP '+res.status);

    rmSpecialTyping(which);
    const el=addSpecialAI(which);
    el.textContent='';

    const reader=res.body.getReader();
    const dec=new TextDecoder();
    let full='';
    const msgsEl=document.getElementById(which+'-msgs');

    while(true){
      const {done,value}=await reader.read();
      if(done)break;
      // Ollama streams newline-delimited JSON
      dec.decode(value).split('\n').forEach(line=>{
        if(!line.trim())return;
        try{
          const d=JSON.parse(line);
          const tok=d?.message?.content;
          if(tok){
            full+=tok;
            el.innerHTML=mdRender(full);
    // Render LaTeX if KaTeX loaded
    if(window.renderMathInElement){try{renderMathInElement(el,{delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\(',right:'\\)',display:false},{left:'\\[',right:'\\]',display:true}],throwOnError:false});}catch(e){}}
            if(msgsEl)msgsEl.scrollTop=msgsEl.scrollHeight;
          }
        }catch(e){}
      });
    }

    if(!full)full='No response.';
    if(!spMsgs[which])spMsgs[which]=[];
  (spMsgs[which]||[]).push({role:'assistant',content:full});
    el.innerHTML=mdRender(full);
    // Render LaTeX if KaTeX loaded
    if(window.renderMathInElement){try{renderMathInElement(el,{delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\(',right:'\\)',display:false},{left:'\\[',right:'\\]',display:true}],throwOnError:false});}catch(e){}}
    if(msgsEl)msgsEl.scrollTop=msgsEl.scrollHeight;

  }catch(e){
    rmSpecialTyping(which);
    const el=addSpecialAI(which);
    el.innerHTML=`<p style="color:var(--red)"><strong>Cannot reach Ollama.</strong><br>Make sure <code>ollama serve</code> and <code>python start.py</code> are running.<br><small style="color:var(--hint)">${e.message}</small><br><br><button onclick="callSpecialOllama('${which}')" style="padding:6px 12px;border-radius:7px;background:${accentCol};border:none;color:#fff;cursor:pointer;font-family:Outfit,sans-serif;font-size:12px">↺ Retry</button></p>`;
  }

  specialBusy[which]=false;
  const btn=document.getElementById(which+'-sbtn');if(btn)btn.disabled=false;
  const inp=document.getElementById(which+'-inp');if(inp)inp.focus();
}


