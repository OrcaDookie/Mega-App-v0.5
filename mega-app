function applyUsernameStyle(text, s){
  const displayText = s.upper ? text.toUpperCase() : text;
  // Update sidebar username elements
  ['sidebar-username','chat-sidebar-username','acct-name'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el)return;
    if(s.rainbow){
      const colors=['#ff0062','#ff8400','#ffb300','#22c55e','#06b6d4','#7c6aff','#ec4899'];
      el.innerHTML=[...displayText].map((ch,i)=>`<span style="color:${colors[i%(colors||[1]).length]}">${ch}</span>`).join('');
    } else {
      el.textContent=displayText;
      el.style.color=s.color;
    }
    el.style.fontFamily=`'${s.font}',sans-serif`;
    el.style.fontWeight=s.bold?'700':'';
    el.style.fontStyle=s.italic?'italic':'';
