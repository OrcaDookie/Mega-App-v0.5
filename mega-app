  const cf=document.getElementById('pw-confirm')?.value||'';
  const err=document.getElementById('pw-err');
  const showErr=(m)=>{if(err){err.textContent=m;err.style.display='block';}};
  if(!cur||!nw||!cf){showErr('Fill in all fields');return;}
  if((nw||'').length<4){showErr('Password must be at least 4 characters');return;}
  if(nw!==cf){showErr('Passwords do not match');return;}
  if(err)err.style.display='none';
  const res=await api('/api/change-password',{current:cur,newPassword:nw},'POST');
  if(res.error){showErr(res.error);return;}
  ['pw-current','pw-new','pw-confirm'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  alert('Password updated!');
}


