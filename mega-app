  r.setProperty('--surf',v.surf);
  r.setProperty('--surf2',adjustBrightness(v.surf,1.15));
  r.setProperty('--surf3',adjustBrightness(v.surf,1.3));
  r.setProperty('--bdr',v.bdr);
  r.setProperty('--bdr2',adjustBrightness(v.bdr,1.2));
  r.setProperty('--txt',v.txt);
  r.setProperty('--muted',blendColors(v.txt,v.bg,0.45));
  r.setProperty('--hint',blendColors(v.txt,v.bg,0.22));
  r.setProperty('--accent',v.acc);
  r.setProperty('--accent2',adjustBrightness(v.acc,0.8));
  r.setProperty('--uav',v.acc);
  r.setProperty('--code',adjustBrightness(v.bg,0.7));
  localStorage.setItem('customTheme',JSON.stringify(v));
  document.querySelectorAll('.theme-card').forEach(b=>b.classList.remove('selected'));
}

function adjustBrightness(hex,factor){
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  const clamp=v=>Math.min(255,Math.max(0,Math.round(v*factor)));
  return'#'+[clamp(r),clamp(g),clamp(b)].map(x=>x.toString(16).padStart(2,'0')).join('');
}

function blendColors(hex1,hex2,t){
  const p=h=>[parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)];
  const [r1,g1,b1]=p(hex1),[r2,g2,b2]=p(hex2);
  const lerp=(a,b)=>Math.round(a*t+b*(1-t));
  return'#'+[lerp(r1,r2),lerp(g1,g2),lerp(b1,b2)].map(x=>x.toString(16).padStart(2,'0')).join('');
}

