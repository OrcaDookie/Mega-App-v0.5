function calcPress(l){
  const ops={'÷':'/','×':'*','−':'-','+':'+'};
  const dispOps={'÷':'÷','×':'×','−':'−','+':'+'};

  if(l==='C'){calcExpr='';calcResult='0';document.getElementById('calc-sub').textContent='';
    (document.getElementById('calc-expr')||{}).textContent='';(document.getElementById('calc-result')||{}).textContent='0';return}
  if(l==='='){calcEval();return}
  if(l==='⌫'){calcExpr=calcExpr.slice(0,-1);document.getElementById('calc-expr').textContent=calcExpr;return}
  if(l==='±'){calcExpr=calcExpr?'-('+calcExpr+')':'';document.getElementById('calc-expr').textContent=calcExpr;return}

  // functions
  const fnMap={
    'sin':'Math.sin(','cos':'Math.cos(','tan':'Math.tan(',
    'asin':'Math.asin(','acos':'Math.acos(','atan':'Math.atan(',
    'sinh':'Math.sinh(','cosh':'Math.cosh(','tanh':'Math.tanh(',
    '√':'Math.sqrt(','∛':'Math.cbrt(','ln':'Math.log(',
    'log':'Math.log10(','log₂':'Math.log2(','log₁₀':'Math.log10(',
    'exp':'Math.exp(','|x|':'Math.abs(','1/x':'1/(',
    'x²':'**2','xⁿ':'**','n!':'factorial(',
    'π':String(Math.PI),'e':String(Math.E),
    '%':'%','MOD':'%','AND':'&','OR':'|','XOR':'^','NOT':'~','<<':'<<','>>':'>>',
    '0x':'0x','0b':'0b',
  };
  if(fnMap[l]!==undefined){calcExpr+=fnMap[l];document.getElementById('calc-expr').textContent=calcExpr;return}
  if(l in ops){calcExpr+=ops[l];document.getElementById('calc-expr').textContent=calcExpr;return}
  if(['A','B','C','D','E','F'].includes(l)&&calcMode==='prog'){calcExpr+=l;document.getElementById('calc-expr').textContent=calcExpr;return}

  calcExpr+=l;
  (document.getElementById('calc-expr')||{}).textContent=calcExpr;
