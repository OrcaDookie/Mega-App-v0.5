function applyLang(code, btn){
  currentLangCode = code;
  const s = LANG_STRINGS[code] || LANG_STRINGS.en;
  localStorage.setItem('lang', code);

  // RTL
  document.body.dir = s.dir || 'ltr';
  document.documentElement.lang = code;

  // Helpers
  const sp  = (id, val) => { const el=document.getElementById(id); if(el) el.placeholder=val; };
  const st  = (id, val) => { const el=document.getElementById(id); if(el) el.textContent=val; };
  const sv  = (id, val) => { const el=document.getElementById(id); if(el) el.value=val; };
  const sq  = (sel, val) => { document.querySelectorAll(sel).forEach(el=>el.textContent=val); };

  // ── Chat placeholders ──
  sp('inp',           s.msgPlaceholder);
  sp('abstract-inp',  s.aiPlaceholderAbstract);
  sp('void-inp',      s.aiPlaceholderVoid);
  sp('dark-inp',      s.aiPlaceholderDark);
  sp('pure-inp',      s.aiPlaceholderPure);
  sp('fire-inp',      s.aiPlaceholderFire);
  sp('lava-inp',      s.aiPlaceholderLava);

  // ── Nav tooltips ──
  const tips = {
    chat:s.tipChat, calc:s.tipCalc, color:s.tipColor, code:s.tipCode,
    Settings:s.tipSettings, Achievements:s.tipAch,
    'Abstract AI — Math':s.tipAbstract, 'Void AI — Geography':s.tipVoid,
    'Dark AI — Language & Writing':s.tipDark, 'Pure AI — Science':s.tipPure,
    'Fire AI — Chemistry':s.tipFire, 'Lava AI — Music':s.tipLava,
  };
  document.querySelectorAll('.nav-btn .tip').forEach(el => {
    const orig = el.textContent.trim();
    if(tips[orig]) el.textContent = tips[orig];
  });

  // ── Chat sidebar ──
  st('topbar-model',    s.modelLabel || 'Claude Sonnet 4');
  document.querySelectorAll('.local-tag').forEach(el=>el.textContent='⚡ '+s.localTag);
  document.querySelectorAll('.new-btn').forEach(el=>{ if(el.textContent.trim().startsWith('+')||el.textContent.includes('chat')||el.textContent.includes('New')) el.firstChild.textContent=' '+s.newChat; });

  // ── Quick chips ──
  const chips = document.querySelectorAll('.chip, .qchip');
  const chipMap = [s.chipShorter,s.chipExamples,s.chipDiff,s.chipPros,s.chipArabic,s.chipFunny,s.chipContinue];
  chips.forEach((el,i)=>{ if(chipMap[i]) el.textContent=chipMap[i]; });

  // ── Tool mode buttons ──
  const tools = document.querySelectorAll('.tool');
  const toolMap = [s.toolConcise,s.toolDeep,s.toolCode,s.toolArabic,s.toolFrench];
  tools.forEach((el,i)=>{ if(toolMap[i]) el.textContent=(el.classList.contains('on')?'✓ ':'')+toolMap[i]; });

  // ── Ollama setup ──
  st('stxt', s.statusChecking);
  document.querySelectorAll('.stitle').forEach((el,i)=>{
    const titles=[s.setupStep1,s.setupStep2,s.setupStep3];
    if(titles[i]) el.textContent=titles[i];
  });
  document.querySelectorAll('.sdesc a[href="https://ollama.com"]').forEach(el=>el.parentElement.firstChild && null);

  // ── Account screen ──
  st('tab-signin',  s.tabSignin);
  st('tab-signup',  s.tabSignup);
  document.querySelectorAll('.start-btn').forEach(el=>el.textContent=s.startBtn||s.signinBtn);
  sp('si-user',  s.fieldUser);
  sp('si-pass',  s.fieldPass);
  sp('su-user',  s.fieldNewUser);
  sp('su-email', s.fieldEmail);
  sp('su-pass',  s.fieldPass);

  // ── Settings labels ──
  const sectionH2s = document.querySelectorAll('.custom-section h2');
  const sectionMap = [
    s.settingsTheme, s.settingsAccent, s.settingsCustomTheme,
    s.settingsFont, s.settingsFontSize, s.settingsAppName,
    s.settingsAIs, s.settingsLang, s.settingsReset,
    s.settingsAccount, s.settingsReset
  ];
  sectionH2s.forEach((el,i)=>{ if(sectionMap[i]){ const icon=el.textContent.slice(0,2); el.textContent=icon+' '+sectionMap[i]; }});

  // ── Achievement panel ──
  st('ach-title-label', s.achTitle);
  st('stat-messages-label', s.achMessages);
  st('stat-chats-label',    s.achChats);
  st('stat-ais-label',      s.achAIs);
