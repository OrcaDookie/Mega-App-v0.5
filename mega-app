var calYear=new Date().getFullYear(), calMonth=new Date().getMonth();
var CAL_MONTHS=["January","February","March","April","May","June","July","August","September","October","November","December"];
var CAL_DAYS=["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
var CAL_EVENTS=[
  {month:0,day:1,title:"New Year Day",color:"#7c6aff"},
  {month:1,day:14,title:"Valentines Day",color:"#ff6b9d"},
  {month:2,day:8,title:"International Womens Day",color:"#ff0062"},
  {month:2,day:17,title:"St Patricks Day",color:"#22c55e"},
  {month:3,day:1,title:"April Fools Day",color:"#ffb300"},
  {month:3,day:22,title:"Earth Day",color:"#22c55e"},
  {month:4,day:4,title:"Star Wars Day",color:"#7700ff"},
  {month:5,day:21,title:"World Music Day",color:"#ff5500"},
  {month:6,day:4,title:"Independence Day",color:"#ff0000"},
  {month:8,day:13,title:"Programmers Day",color:"#4d4d4d"},
  {month:9,day:31,title:"Halloween",color:"#ff8400"},
  {month:10,day:11,title:"Veterans Day",color:"#1565c0"},
  {month:11,day:25,title:"Christmas Day",color:"#22c55e"},
  {month:11,day:31,title:"New Years Eve",color:"#7c6aff"}
];
function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCal();}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCal();}
function renderCal(){
  var lbl=document.getElementById('cal-month-label');
  if(lbl)lbl.textContent=CAL_MONTHS[calMonth]+' '+calYear;
  var grid=document.getElementById('cal-grid');if(!grid)return;
  var first=new Date(calYear,calMonth,1).getDay();
  var days=new Date(calYear,calMonth+1,0).getDate();
  var today=new Date();
  var evts=CAL_EVENTS.filter(function(e){return e.month===calMonth;});
  var html='';
  CAL_DAYS.forEach(function(d){html+='<div style="text-align:center;font-size:11px;font-weight:600;color:var(--muted);padding:4px 0">'+d+'</div>';});
  for(var i=0;i<first;i++)html+='<div></div>';
  for(var d=1;d<=days;d++){
    var isToday=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
    var ev=evts.find(function(e){return e.day===d;});
    html+='<div style="aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:13px;font-weight:'+(isToday?'700':'400')+';background:'+(isToday?'var(--accent)':ev?ev.color+'22':'var(--surf2)')+';color:'+(isToday?'#fff':ev?ev.color:'var(--txt)')+';border:1px solid '+(isToday?'var(--accent)':ev?ev.color+'55':'var(--bdr)')+'">'+d+'</div>';
  }
  grid.innerHTML=html;
  var evEl=document.getElementById('cal-events');if(!evEl)return;
  if(!evts.length){evEl.innerHTML='<div style="font-size:13px;color:var(--hint);text-align:center;padding:16px">No events this month</div>';return;}
  evEl.innerHTML='<div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Events this month</div>'
    +evts.map(function(e){return '<div style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:var(--sb);border:1px solid var(--bdr);border-left:3px solid '+e.color+';border-radius:10px"><div style="text-align:center;flex-shrink:0;min-width:36px"><div style="font-size:10px;color:var(--muted)">'+CAL_MONTHS[e.month].slice(0,3)+'</div><div style="font-size:16px;font-weight:700;color:'+e.color+'">'+e.day+'</div></div><div style="font-size:13px;font-weight:600;color:var(--txt)">'+e.title+'</div></div>';}).join('');
}

