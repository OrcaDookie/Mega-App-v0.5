function escH(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function chatScroll(){const m=document.getElementById('msgs');m.scrollTop=m.scrollHeight}

function mdRender(text){
  let h=escH(text);
  h=h.replace(/```(\w*)\n?([\s\S]*?)```/g,(_,l,c)=>`<pre><div class="phead"><span class="plang">${l||'code'}</span><button class="cpb" onclick="cpPre(this)">Copy</button></div><code>${c.trim()}</code></pre>`);
  h=h.replace(/`([^`\n]+)`/g,'<code>$1</code>');
  h=h.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  h=h.replace(/\*([^*\n]+)\*/g,'<em>$1</em>');
  h=h.replace(/^### (.+)$/gm,'<h3>$1</h3>');
  h=h.replace(/^## (.+)$/gm,'<h2>$1</h2>');
  h=h.replace(/^# (.+)$/gm,'<h1>$1</h1>');
  h=h.replace(/^> (.+)$/gm,'<blockquote>$1</blockquote>');
  h=h.replace(/^\d+\. (.+)$/gm,'<li style="list-style:decimal">$1</li>');
  h=h.replace(/^[-*] (.+)$/gm,'<li>$1</li>');
  h=h.replace(/(<li[^>]*>[\s\S]*?<\/li>\n?)+/g,m=>`<ul>${m}</ul>`);
  return h.split(/\n\n+/).map(p=>{p=p.trim();if(!p)return'';if(/^<(h[123]|pre|ul|blockquote)/.test(p))return p;return`<p>${p.replace(/\n/g,'<br>')}</p>`;}).join('');
}

function cpPre(btn){navigator.clipboard.writeText(btn.closest('pre').querySelector('code').innerText).then(()=>{btn.textContent='Copied!';setTimeout(()=>btn.textContent='Copy',1500)})}

function addUserMsg(text){
