function factorial(n){if(n<0)return NaN;if(n===0||n===1)return 1;let r=1;for(let i=2;i<=n;i++)r*=i;return r}

function calcSafeEval(expr){
  try{
    let e=expr.replace(/÷/g,'/').replace(/×/g,'*').replace(/−/g,'-');
    // close unclosed parens
    const opens=(e.match(/\(/g)||[]).length-(e.match(/\)/g)||[]).length;
    e+=')'.repeat(Math.max(0,opens));
    const result=Function('"use strict";const factorial='+factorial.toString()+';return ('+e+')')();
    if(!isFinite(result))return null;
    return parseFloat(result.toPrecision(12));
  }catch(e){return null}
}

