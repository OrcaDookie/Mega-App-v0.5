function updateProfilePreview(){
  const text = document.getElementById('profile-username-inp')?.value || 'Your Name';
  const size = document.getElementById('username-size-slider')?.value || 16;
  const szlbl=document.getElementById('username-size-label');if(szlbl)szlbl.textContent=size+'px';
  usernameState.text = text;
  usernameState.size = +size;

  const preview = document.getElementById('profile-name-preview');
  if(!preview) return;

  let style = `font-family:'${usernameState.font}',sans-serif;font-size:${size}px;`;
  let color = usernameState.color;
  let displayText = usernameState.upper ? text.toUpperCase() : text;

  if(usernameState.rainbow){
    // Rainbow: wrap each char in a span
    const colors = ['#ff0062','#ff8400','#ffb300','#22c55e','#06b6d4','#7c6aff','#ec4899'];
    preview.innerHTML = [...displayText].map((ch,i)=>`<span style="color:${colors[i%(colors||[1]).length]}">${ch}</span>`).join('');
  } else {
    preview.textContent = displayText;
    preview.style.color = color;
  }
  preview.style.fontFamily = `'${usernameState.font}',sans-serif`;
  preview.style.fontSize = size+'px';
  preview.style.fontWeight = usernameState.bold ? '700' : '700';
  preview.style.fontStyle = usernameState.italic ? 'italic' : 'normal';
  let decoration = [];
  if(usernameState.underline) decoration.push('underline');
  if(usernameState.strike) decoration.push('line-through');
  preview.style.textDecoration = decoration.join(' ') || 'none';
  preview.style.textShadow = usernameState.shadow ? '2px 2px 8px rgba(124,106,255,.8)' : 'none';
  preview.style.webkitTextStroke = usernameState.outline ? '1px currentColor' : '';

  // Update pfp preview
  renderPfpCanvas();
  const avPrev = document.getElementById('profile-av-preview');
  if(avPrev){
    const border = usernameState.color !== 'var(--txt)' ? usernameState.color : 'var(--accent)';
    avPrev.style.border = `3px solid ${border}`;
  }
}

