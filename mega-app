<div class="panel" class="panel active" id="panel-calc">
  <div class="calc-wrap">
    <div class="calc-modes">
      <div style="font-size:10px;color:var(--hint);text-transform:uppercase;letter-spacing:.06em;font-weight:600;padding:4px 6px;margin-bottom:6px">Mode</div>
      <button class="calc-mode-btn active" onclick="setCalcMode('basic',this)">🔢 Basic</button>
      <button class="calc-mode-btn" onclick="setCalcMode('sci',this)">🔬 Scientific</button>
      <button class="calc-mode-btn" onclick="setCalcMode('ultra',this)">⚛️ Ultra-Sci</button>
      <button class="calc-mode-btn" onclick="setCalcMode('prog',this)">💻 Programmer</button>
      <div style="border-top:1px solid var(--bdr);margin:8px 0"></div>
      <div style="font-size:10px;color:var(--hint);text-transform:uppercase;letter-spacing:.06em;font-weight:600;padding:4px 6px;margin-bottom:4px">History</div>
      <div id="calc-hist" style="flex:1;overflow-y:auto;font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;padding:0 4px;display:flex;flex-direction:column;gap:3px"></div>
