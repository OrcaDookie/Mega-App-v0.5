function getUsers(){
  return safeLS('mega-users', {});
}

function saveUsers(users){
  localStorage.setItem('mega-users',JSON.stringify(users));
}

function doSignIn(){
  const user=document.getElementById('si-user').value.trim();
  const pass=document.getElementById('si-pass').value;
  const err=document.getElementById('si-err');
  if(!user||!pass){err.textContent='Fill in both fields, genius 😄';err.style.display='block';return;}
  const users=getUsers();
  const found=Object.values(users).find(u=>u.username===user||u.email===user);
  if(!found||found.password!==btoa(pass)){
    err.textContent='Wrong username or password. Did you forget already? 😅';err.style.display='block';return;
  }
  err.style.display='none';
  loginUser(found);
}

function doSignUp(){
  const user=document.getElementById('su-user').value.trim();
  const email=document.getElementById('su-email').value.trim();
  const pass=document.getElementById('su-pass').value;
  const err=document.getElementById('su-err');
  if(!user||!pass){err.textContent='Username and password are kinda required 😇';err.style.display='block';return;}
  if((pass||'').length<4){err.textContent='Password needs at least 4 chars. Even "1234" is better than nothing 😂';err.style.display='block';return;}
  const users=getUsers();
  if(Object.values(users).find(u=>u.username===user)){
    err.textContent='Username taken! Someone cooler got there first 😎';err.style.display='block';return;
  }
  const newUser={id:'u'+Date.now(),username:user,email:email||'',password:btoa(pass),joined:new Date().toLocaleDateString()};
  users[newUser.id]=newUser;
  saveUsers(users);
  err.style.display='none';
  trackAccount();
  loginUser(newUser, true);
}

