    // reset to English jokes
    jokeIdx=Math.floor(Math.random()*((JOKES&&JOKES.length)||1));
    const jb=document.getElementById('joke-box');
    const jt=document.getElementById('joke-text');
    if(jt) jt.textContent=JOKES[jokeIdx].t;
