<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache,no-store,must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mega App</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f0f11;--sb:#111113;--surf:#1a1a1e;--surf2:#222226;--surf3:#2a2a30;
  --bdr:#2a2a30;--bdr2:#333340;--txt:#f0f0f5;--muted:#8888a0;--hint:#44445a;
  --accent:#7c6aff;--accent2:#5b4fcf;--green:#22c55e;--red:#ef4444;--amber:#f59e0b;
  --blue:#3b82f6;--pink:#ec4899;--cyan:#06b6d4;
  --code:#0d0d14;--uav:#7c6aff;--radius:10px;
}
html,body{height:100%;overflow:hidden;font-family:'Outfit',sans-serif}
body{background:var(--bg);color:var(--txt);display:flex;flex-direction:column}

/* ─── LAYOUT ─── */
.shell{display:flex;height:100%;overflow:hidden}
.sidebar{width:62px;background:var(--sb);border-right:1px solid var(--bdr);display:flex;flex-direction:column;align-items:center;padding:12px 0;gap:4px;flex-shrink:0;z-index:10;overflow-y:auto;overflow-x:hidden}.sidebar::-webkit-scrollbar{width:3px}.sidebar::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:3px}
.nav-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--pink));display:flex;align-items:center;justify-content:center;font-size:17px;margin-bottom:12px;cursor:pointer}
.nav-btn{width:40px;height:40px;border-radius:10px;background:transparent;border:none;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;transition:all .2s;position:relative}
.nav-btn:hover{background:var(--surf2);color:var(--txt)}
.nav-btn.active{background:var(--accent);color:#fff}
.nav-btn .tip{position:absolute;left:52px;background:var(--surf3);color:var(--txt);font-size:11px;padding:4px 8px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s;border:1px solid var(--bdr2);font-family:'Outfit',sans-serif}
.nav-btn:hover .tip{opacity:1}
.nav-sep{width:24px;height:1px;background:var(--bdr);margin:4px 0}
.panel{flex:1;display:none;overflow:hidden;flex-direction:column}.panel.active{display:flex!important}.panel:not(.active){display:none!important}
.panel.active{display:flex}

/* ─── CHAT ─── */
.chat-layout{display:flex;height:100%}
.chat-sb{width:220px;background:var(--sb);border-right:1px solid var(--bdr);display:flex;flex-direction:column;flex-shrink:0}
.chat-sb-top{padding:12px 10px 8px;border-bottom:1px solid var(--bdr)}
.chat-logo{display:flex;align-items:center;gap:7px;margin-bottom:10px}
.chat-logo-ic{width:24px;height:24px;border-radius:7px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:12px}
.chat-logo-txt{font-size:13px;font-weight:600}
.new-btn{width:100%;padding:7px 10px;border-radius:8px;background:transparent;border:1px solid var(--bdr);color:var(--muted);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:inherit;transition:all .15s}
.new-btn:hover{background:var(--surf2);color:var(--txt)}
.cl{flex:1;overflow-y:auto;padding:4px 5px}
.ci{padding:7px 10px;font-size:12px;color:var(--muted);cursor:pointer;border-radius:7px;margin:1px 0;display:flex;align-items:center;gap:6px;white-space:nowrap;overflow:hidden;transition:all .15s}
.ci:hover,.ci.on{background:var(--surf2);color:var(--txt)}
.ci span:last-child{flex:1;overflow:hidden;text-overflow:ellipsis}
.chat-sb-bot{padding:8px;border-top:1px solid var(--bdr);margin-top:auto}
.model-badge{display:flex;align-items:center;gap:6px;padding:7px 9px;border-radius:8px;background:var(--surf2);font-size:11px;cursor:pointer;border:1px solid var(--bdr)}
.mdot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0}
.chat-main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden}
.chat-topbar{padding:9px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--bdr);flex-shrink:0}
.mpill{display:flex;align-items:center;gap:5px;padding:5px 9px;border-radius:7px;background:var(--surf2);font-size:12px;font-weight:500;border:1px solid var(--bdr)}
.local-tag{font-size:10px;color:var(--green);background:rgba(34,197,94,.1);padding:2px 7px;border-radius:20px;border:1px solid rgba(34,197,94,.2);font-weight:500}
.msgs{flex:1;overflow-y:auto;padding:16px 0;display:flex;flex-direction:column}
.msgs::-webkit-scrollbar{width:3px}
.msgs::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:3px}
.mrow{padding:8px 0;width:100%}
.mrow:hover{background:rgba(255,255,255,.01)}
.mi{max-width:680px;margin:0 auto;padding:0 20px;display:flex;gap:11px;align-items:flex-start}
.mrow.u .mi{flex-direction:row-reverse}
.mav{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;margin-top:2px}
.mav.ai{background:var(--accent)}.mav.u{background:var(--uav)}
.mb{flex:1;min-width:0}
.mn{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:4px;font-family:'JetBrains Mono',monospace}
.mt{font-size:13.5px;line-height:1.75;color:#c8c8d8}
.mt p{margin-bottom:8px}.mt p:last-child{margin-bottom:0}
.mt strong{color:var(--txt);font-weight:600}
.mt em{color:#a78bfa}
.mt h1,.mt h2,.mt h3{color:var(--txt);font-weight:600;margin:10px 0 4px}
.mt h1{font-size:16px}.mt h2{font-size:14px}.mt h3{font-size:13px}
.mt ul,.mt ol{padding-left:18px;margin:6px 0}
.mt li{margin-bottom:4px;color:#c8c8d8;line-height:1.6}
.mt blockquote{border-left:2px solid var(--accent);padding-left:12px;margin:8px 0;color:var(--muted)}
.mt code{background:var(--code);padding:2px 5px;border-radius:4px;font-size:11.5px;font-family:'JetBrains Mono',monospace;color:#a78bfa;border:1px solid #1e1e30}
.mt pre{background:var(--code);border:1px solid #1e1e30;border-radius:9px;margin:10px 0;overflow:hidden}
.phead{display:flex;justify-content:space-between;align-items:center;padding:6px 12px;border-bottom:1px solid #1e1e30;background:#0a0a10}
.plang{font-size:10px;color:#666;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.05em}
.cpb{background:none;border:none;color:#666;font-size:11px;cursor:pointer;padding:2px 5px;border-radius:3px;font-family:'Outfit',sans-serif;transition:all .15s}
.cpb:hover{color:var(--txt)}
.mt pre code{background:transparent;border:none;padding:12px;display:block;white-space:pre;overflow-x:auto;color:#c084fc;font-size:12px;line-height:1.6}
.ma{display:flex;gap:2px;margin-top:7px;opacity:0;transition:opacity .15s}
.mrow:hover .ma{opacity:1}
.mac{padding:3px 7px;border-radius:5px;background:transparent;border:none;color:var(--muted);font-size:11px;cursor:pointer;transition:all .15s;font-family:'Outfit',sans-serif}
.mac:hover{background:var(--surf2);color:var(--txt)}
.trow{padding:8px 0}
.ti{max-width:680px;margin:0 auto;padding:0 20px;display:flex;gap:11px;align-items:center}
.dots{display:flex;gap:4px}
.dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pu 1s ease-in-out infinite}
.dot:nth-child(2){animation-delay:.18s}.dot:nth-child(3){animation-delay:.36s}
@keyframes pu{0%,80%,100%{opacity:.25;transform:scale(.8)}40%{opacity:1;transform:scale(1)}}
.wlc{max-width:640px;margin:36px auto 0;padding:0 20px;text-align:center}
.wt{font-size:22px;font-weight:700;color:var(--txt);margin-bottom:6px;letter-spacing:-.02em}
.ws{font-size:13px;color:var(--muted);margin-bottom:22px}
.wg{display:grid;grid-template-columns:1fr 1fr;gap:7px;text-align:left}
.wc{padding:12px 13px;border-radius:9px;border:1px solid var(--bdr);background:var(--sb);cursor:pointer;transition:all .18s}
.wc:hover{border-color:var(--bdr2);background:var(--surf2);transform:translateY(-1px)}
.wi{font-size:16px;margin-bottom:6px}
.wtt{font-size:12px;font-weight:500;color:var(--txt);margin-bottom:2px}
.wd{font-size:11px;color:var(--hint)}
.chat-ia{padding:10px 16px 14px;background:var(--bg);flex-shrink:0}
.chat-iw{max-width:680px;margin:0 auto}
.chips{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:7px}
.chip{padding:4px 9px;border-radius:20px;border:1px solid var(--bdr);background:transparent;color:var(--hint);font-size:11px;cursor:pointer;transition:all .15s;font-family:'Outfit',sans-serif}
.chip:hover{border-color:var(--accent);color:var(--accent)}
.ibox{background:var(--surf);border:1px solid var(--bdr);border-radius:13px;overflow:hidden;transition:border-color .2s}
.ibox:focus-within{border-color:var(--accent)}
.tbar{display:flex;gap:4px;padding:7px 11px 6px;border-bottom:1px solid var(--bdr);flex-wrap:wrap}
.tool{padding:4px 8px;border-radius:20px;border:1px solid var(--bdr);background:transparent;color:var(--muted);font-size:11px;cursor:pointer;transition:all .15s;font-family:'Outfit',sans-serif}
.tool:hover{border-color:var(--accent);color:var(--accent)}
.tool.on{background:var(--accent);color:#fff;border-color:var(--accent)}
.irow{display:flex;align-items:flex-end;gap:7px;padding:8px 11px 10px}
.inp{flex:1;background:transparent;border:none;outline:none;color:var(--txt);font-size:13.5px;resize:none;font-family:'Outfit',sans-serif;max-height:130px;line-height:1.6}
.inp::placeholder{color:var(--hint)}
.sbtn{width:30px;height:30px;border-radius:8px;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;transition:all .15s;flex-shrink:0;font-size:15px}
.sbtn:hover{background:var(--accent2)}
.sbtn:disabled{background:var(--bdr);cursor:not-allowed}
.chat-fn{text-align:center;font-size:10px;color:var(--hint);margin-top:7px}

/* ─── SETUP ─── */
.setup-wrap{display:flex;align-items:center;justify-content:center;height:100%;padding:24px;background:var(--bg)}
.setup-card{background:var(--sb);border:1px solid var(--bdr);border-radius:16px;padding:28px;max-width:480px;width:100%}
.setup-hd{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.setup-ic{width:34px;height:34px;border-radius:9px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:17px}
.status-row{display:flex;align-items:center;gap:8px;margin-bottom:18px;padding:9px 12px;border-radius:8px;background:var(--surf);border:1px solid var(--bdr);font-size:12px}
.sdot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sdot.on{background:var(--green);box-shadow:0 0 0 3px rgba(34,197,94,.15)}
.sdot.off{background:var(--red)}
.sdot.chk{background:var(--amber);animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.steps{margin-bottom:20px}
.step{display:flex;gap:11px;margin-bottom:14px;align-items:flex-start}
.snum{width:22px;height:22px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;margin-top:1px}
.stitle{font-size:13px;font-weight:500;color:var(--txt);margin-bottom:3px}
.sdesc{font-size:12px;color:var(--muted);line-height:1.6}
.sdesc a{color:var(--accent);text-decoration:none}
.sdesc code{background:var(--surf2);padding:2px 6px;border-radius:4px;font-family:'JetBrains Mono',monospace;font-size:11px;color:#c084fc}
.msel{flex:1;padding:8px 10px;border-radius:8px;background:var(--surf);border:1px solid var(--bdr);color:var(--txt);font-size:13px;font-family:'Outfit',sans-serif;outline:none;cursor:pointer}
.msel:focus{border-color:var(--accent)}
.start-btn{width:100%;padding:11px;border-radius:10px;background:var(--accent);border:none;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;letter-spacing:.01em}
.start-btn:hover{background:var(--accent2)}

/* ─── CALCULATOR ─── */
.calc-wrap{display:flex;height:100%;overflow:hidden;background:var(--bg)}
.calc-modes{width:160px;background:var(--sb);border-right:1px solid var(--bdr);padding:12px 8px;display:flex;flex-direction:column;gap:4px;flex-shrink:0}
.calc-mode-btn{padding:9px 12px;border-radius:8px;background:transparent;border:none;color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;text-align:left;font-family:'Outfit',sans-serif;transition:all .15s;display:flex;align-items:center;gap:8px}
.calc-mode-btn:hover{background:var(--surf2);color:var(--txt)}
.calc-mode-btn.active{background:var(--accent);color:#fff}
.calc-main{flex:1;display:flex;flex-direction:column;overflow:hidden;padding:20px}
.calc-display{background:var(--surf);border:1px solid var(--bdr);border-radius:12px;padding:16px 20px;margin-bottom:16px;text-align:right;flex-shrink:0}
.calc-expr{font-size:12px;color:var(--muted);font-family:'JetBrains Mono',monospace;min-height:18px;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.calc-result{font-size:32px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--txt);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;letter-spacing:-.02em}
.calc-sub{font-size:11px;color:var(--muted);margin-top:2px;font-family:'JetBrains Mono',monospace;min-height:16px}
.calc-grid{display:grid;gap:8px;flex:1}
.cb{padding:0;border-radius:9px;border:none;font-size:14px;font-weight:500;cursor:pointer;font-family:'JetBrains Mono',monospace;transition:all .12s;display:flex;align-items:center;justify-content:center;min-height:44px}
.cb:hover{filter:brightness(1.15)}
.cb:active{transform:scale(.95)}
.cb.num{background:var(--surf2);color:var(--txt)}
.cb.op{background:var(--surf3);color:var(--amber)}
.cb.fn{background:var(--surf);color:var(--cyan);font-size:12px}
.cb.eq{background:var(--accent);color:#fff;font-size:18px}
.cb.clr{background:rgba(239,68,68,.15);color:var(--red)}
.cb.mem{background:rgba(124,106,255,.12);color:var(--accent);font-size:11px}
.cb.span2{grid-column:span 2}
.cb.span3{grid-column:span 3}

/* ─── COLOR PICKER ─── */
.color-wrap{display:flex;height:100%;overflow:hidden;background:var(--bg);padding:20px;gap:20px}
.color-left{width:300px;flex-shrink:0;display:flex;flex-direction:column;gap:14px}
.color-right{flex:1;display:flex;flex-direction:column;gap:14px;overflow-y:auto}
.color-section{background:var(--sb);border:1px solid var(--bdr);border-radius:12px;padding:16px}
.color-section h3{font-size:12px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px}
.color-preview-big{width:100%;height:120px;border-radius:10px;border:1px solid var(--bdr);margin-bottom:12px;transition:background .1s}
.color-sliders{display:flex;flex-direction:column;gap:8px}
.color-slider-row{display:flex;align-items:center;gap:8px}
.color-slider-label{font-size:11px;color:var(--muted);font-family:'JetBrains Mono',monospace;width:14px;text-align:center}
.color-slider{flex:1;height:4px;border-radius:2px;outline:none;cursor:pointer;-webkit-appearance:none;appearance:none}
.color-slider::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:#fff;border:2px solid var(--bdr2);cursor:pointer}
.color-val{font-size:11px;color:var(--txt);font-family:'JetBrains Mono',monospace;width:30px;text-align:right}
.color-hex-row{display:flex;gap:8px;align-items:center}
.color-hex-inp{flex:1;padding:8px 10px;border-radius:8px;background:var(--surf2);border:1px solid var(--bdr);color:var(--txt);font-size:13px;font-family:'JetBrains Mono',monospace;outline:none}
.color-hex-inp:focus{border-color:var(--accent)}
.color-copy-btn{padding:8px 12px;border-radius:8px;background:var(--accent);border:none;color:#fff;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;white-space:nowrap}
.color-copy-btn:hover{background:var(--accent2)}
.color-swatches{display:grid;grid-template-columns:repeat(8,1fr);gap:6px}
.swatch{width:100%;aspect-ratio:1;border-radius:7px;cursor:pointer;border:2px solid transparent;transition:all .15s}
.swatch:hover{transform:scale(1.1);border-color:var(--txt)}
.palette-row{display:flex;gap:6px;flex-wrap:wrap}
.pal-swatch{width:32px;height:32px;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:all .15s;flex-shrink:0}
.pal-swatch:hover{transform:scale(1.1);border-color:var(--txt)}
.color-formats{display:flex;flex-direction:column;gap:6px}
.fmt-row{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;background:var(--surf2)}
.fmt-label{font-size:10px;color:var(--muted);font-family:'JetBrains Mono',monospace;width:40px;flex-shrink:0;text-transform:uppercase}
.fmt-val{flex:1;font-size:12px;color:var(--txt);font-family:'JetBrains Mono',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fmt-cp{padding:3px 7px;border-radius:5px;background:transparent;border:1px solid var(--bdr);color:var(--muted);font-size:10px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;flex-shrink:0}
.fmt-cp:hover{border-color:var(--accent);color:var(--accent)}
.harmony-grid{display:flex;gap:8px;flex-wrap:wrap}
.harmony-swatch{display:flex;flex-direction:column;align-items:center;gap:4px}
.harmony-color{width:44px;height:44px;border-radius:9px;cursor:pointer;border:2px solid transparent;transition:all .15s}
.harmony-color:hover{transform:scale(1.05);border-color:var(--txt)}
.harmony-label{font-size:9px;color:var(--muted);font-family:'JetBrains Mono',monospace}
.saved-colors{display:flex;gap:6px;flex-wrap:wrap}
.saved-c{width:36px;height:36px;border-radius:8px;cursor:pointer;border:2px solid transparent;transition:all .15s;position:relative}
.saved-c:hover{transform:scale(1.08);border-color:var(--txt)}
.save-color-btn{padding:8px 14px;border-radius:8px;background:var(--surf2);border:1px solid var(--bdr);color:var(--txt);font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;margin-top:4px}
.save-color-btn:hover{background:var(--surf3);border-color:var(--bdr2)}
.eyedropper-btn{padding:8px 14px;border-radius:8px;background:transparent;border:1px solid var(--bdr);color:var(--muted);font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;display:flex;align-items:center;gap:6px}
.eyedropper-btn:hover{background:var(--surf2);color:var(--txt)}

/* ─── CODE RUNNER ─── */
.code-wrap{display:flex;height:100%;overflow:hidden}
.code-sb{width:160px;background:var(--sb);border-right:1px solid var(--bdr);display:flex;flex-direction:column;padding:12px 8px;gap:3px;flex-shrink:0}
.code-sb h3{font-size:10px;color:var(--hint);text-transform:uppercase;letter-spacing:.06em;font-weight:600;padding:4px 6px;margin-bottom:4px}
.lang-btn{padding:8px 10px;border-radius:7px;background:transparent;border:none;color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;text-align:left;font-family:'JetBrains Mono',monospace;transition:all .15s;display:flex;align-items:center;gap:7px}
.lang-btn:hover{background:var(--surf2);color:var(--txt)}
.lang-btn.active{background:var(--accent);color:#fff}
.lang-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.code-main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.code-topbar{padding:10px 16px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.code-title{font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.run-btn{padding:7px 16px;border-radius:8px;background:var(--green);border:none;color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;display:flex;align-items:center;gap:6px}
.run-btn:hover{filter:brightness(1.1)}
.run-btn:disabled{background:var(--bdr);cursor:not-allowed}
.code-body{flex:1;display:flex;overflow:hidden}
.editor-wrap{flex:1;display:flex;flex-direction:column;border-right:1px solid var(--bdr);overflow:hidden}
.editor-hd{padding:8px 14px;border-bottom:1px solid var(--bdr);font-size:11px;color:var(--muted);display:flex;align-items:center;justify-content:space-between}
.code-editor{flex:1;padding:14px;background:var(--code);color:#e2e8f0;font-size:13px;font-family:'JetBrains Mono',monospace;border:none;outline:none;resize:none;line-height:1.7;tab-size:2;overflow-y:auto}
.code-editor::-webkit-scrollbar{width:4px}
.code-editor::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:2px}
.output-wrap{width:340px;display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
.output-hd{padding:8px 14px;border-bottom:1px solid var(--bdr);font-size:11px;color:var(--muted);display:flex;align-items:center;justify-content:space-between}
.output-body{flex:1;overflow-y:auto;padding:14px;background:var(--code);font-size:12.5px;font-family:'JetBrains Mono',monospace;line-height:1.7;color:#e2e8f0;white-space:pre-wrap;word-break:break-word}
.output-body::-webkit-scrollbar{width:4px}
.output-body::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:2px}
.out-success{color:var(--green)}
.out-error{color:var(--red)}
.out-info{color:var(--cyan)}
.out-warn{color:var(--amber)}
.clear-out-btn{padding:2px 8px;border-radius:5px;background:transparent;border:1px solid var(--bdr);color:var(--muted);font-size:10px;cursor:pointer;font-family:'Outfit',sans-serif}
.clear-out-btn:hover{border-color:var(--bdr2);color:var(--txt)}
.code-examples{padding:8px 14px;border-top:1px solid var(--bdr);display:flex;gap:6px;flex-wrap:wrap;flex-shrink:0}
.ex-btn{padding:4px 8px;border-radius:6px;background:var(--surf2);border:1px solid var(--bdr);color:var(--muted);font-size:11px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.ex-btn:hover{border-color:var(--accent);color:var(--accent)}
.sandbox-note{font-size:10px;color:var(--hint);padding:4px 14px 8px;font-style:italic}

/* ─── SHARED ─── */
.section-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:10px}
input[type=range]{width:100%;height:4px;border-radius:2px;outline:none;cursor:pointer;-webkit-appearance:none;appearance:none;background:var(--surf3)}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--accent);cursor:pointer;border:2px solid var(--bg)}

/* ── CUSTOMIZATION PANEL ── */
.custom-wrap{display:flex;height:100%;overflow:hidden;background:var(--bg)}
.custom-main{flex:1;overflow-y:auto;padding:24px}
.custom-section{background:var(--sb);border:1px solid var(--bdr);border-radius:12px;padding:20px;margin-bottom:16px}
.custom-section h2{font-size:14px;font-weight:600;color:var(--txt);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.theme-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.theme-card{padding:12px;border-radius:10px;border:2px solid transparent;cursor:pointer;transition:all .18s;text-align:center}
.theme-card:hover{transform:translateY(-2px)}
.theme-card.selected{border-color:var(--accent)}
.theme-dot-row{display:flex;gap:4px;justify-content:center;margin-bottom:6px}
.theme-dot{width:12px;height:12px;border-radius:50%}
.theme-name{font-size:11px;color:var(--muted);font-weight:500}
.accent-grid{display:flex;flex-wrap:wrap;gap:8px}
.accent-btn{width:32px;height:32px;border-radius:50%;border:3px solid transparent;cursor:pointer;transition:all .15s}
.accent-btn:hover,.accent-btn.selected{border-color:var(--txt);transform:scale(1.15)}
.custom-input{width:100%;padding:9px 12px;border-radius:8px;background:var(--surf2);border:1px solid var(--bdr);color:var(--txt);font-size:13px;font-family:'Outfit',sans-serif;outline:none;margin-bottom:8px}
.custom-input:focus{border-color:var(--accent)}
.font-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.font-btn{padding:10px;border-radius:9px;border:1px solid var(--bdr);background:var(--surf2);color:var(--muted);font-size:13px;cursor:pointer;transition:all .15s;text-align:center}
.font-btn:hover,.font-btn.selected{border-color:var(--accent);color:var(--txt);background:var(--surf3)}
.size-row{display:flex;align-items:center;gap:12px}
.size-btn{width:36px;height:36px;border-radius:8px;border:1px solid var(--bdr);background:var(--surf2);color:var(--muted);font-size:14px;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center}
.size-btn:hover,.size-btn.selected{border-color:var(--accent);color:var(--txt)}
.size-preview{flex:1;padding:8px 12px;border-radius:8px;background:var(--surf2);font-size:12px;color:var(--muted)}
.model-card{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:10px;border:1px solid var(--bdr);background:var(--surf2);margin-bottom:8px}
.model-card-ic{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.model-card-info{flex:1}
.model-card-name{font-size:13px;font-weight:600;color:var(--txt)}
.model-card-desc{font-size:11px;color:var(--muted);margin-top:2px}
.model-card-badge{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;flex-shrink:0}
.apply-btn{width:100%;padding:11px;border-radius:10px;background:var(--accent);border:none;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;margin-top:4px}
.apply-btn:hover{background:var(--accent2)}
/* ── FOOTER NOTE ── */
.app-footer{text-align:center;padding:7px 16px;font-size:11px;color:var(--hint);border-top:1px solid var(--bdr);background:var(--sb);flex-shrink:0}
.app-footer a{color:var(--accent);text-decoration:none}
.app-footer a:hover{text-decoration:underline}

/* ── SPECIAL AI PANELS ── */
.special-panel{display:flex;height:100%;flex-direction:column;overflow:hidden}
.special-topbar{padding:10px 18px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--bdr);flex-shrink:0}
.special-avatar{width:36px;height:36px;border-radius:10px;flex-shrink:0;overflow:hidden}
.special-info{flex:1}
.special-name{font-size:14px;font-weight:700;color:var(--txt)}
.special-desc{font-size:11px;color:var(--muted)}
.special-tag{font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px;flex-shrink:0}
.special-msgs{flex:1;overflow-y:auto;padding:16px 0;display:flex;flex-direction:column}
.special-msgs::-webkit-scrollbar{width:3px}
.special-msgs::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:3px}
.special-ia{padding:10px 16px 14px;background:var(--bg);flex-shrink:0}
.special-iw{max-width:680px;margin:0 auto}
.special-ibox{border-radius:13px;overflow:hidden;transition:border-color .2s;border:1px solid var(--bdr)}
.special-ibox:focus-within{border-color:var(--accent)}
.special-irow{display:flex;align-items:flex-end;gap:8px;padding:10px 13px 12px}
.special-inp{flex:1;background:transparent;border:none;outline:none;color:var(--txt);font-size:13.5px;resize:none;font-family:'Outfit',sans-serif;max-height:130px;line-height:1.6}
.special-inp::placeholder{color:var(--hint)}
.special-sbtn{width:32px;height:32px;border-radius:8px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;transition:all .15s;flex-shrink:0;font-size:15px}
.special-sbtn:disabled{opacity:.4;cursor:not-allowed}
.special-wlc{max-width:640px;margin:36px auto 0;padding:0 20px;text-align:center}
.special-wlc .wt{font-size:22px;font-weight:700;margin-bottom:6px}
.special-wlc .ws{font-size:13px;color:var(--muted);margin-bottom:22px}
.apikey-notice{background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:10px 14px;font-size:12px;color:var(--muted);margin:0 20px 12px;max-width:640px;margin-left:auto;margin-right:auto;display:flex;align-items:center;gap:8px}
.apikey-inp{flex:1;padding:7px 10px;border-radius:7px;background:var(--surf3);border:1px solid var(--bdr);color:var(--txt);font-size:12px;font-family:'JetBrains Mono',monospace;outline:none}
.apikey-inp:focus{border-color:var(--accent)}
.apikey-save{padding:7px 12px;border-radius:7px;background:var(--accent);border:none;color:#fff;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;white-space:nowrap}

/* ── ACCOUNT SETUP ── */
#screen-account,#screen-ollama{display:flex;justify-content:center;width:100%}
.setup-wrap{display:flex;align-items:center;justify-content:center;height:100%;padding:24px;background:var(--bg);overflow-y:auto}
.joke-badge{background:var(--surf2);border:1px solid var(--bdr);border-radius:8px;padding:8px 12px;font-size:11px;color:var(--muted);display:flex;align-items:center;gap:8px;margin-bottom:6px}

/* ── DELETE MODAL ── */
.del-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);display:flex;align-items:center;justify-content:center;z-index:9999;backdrop-filter:blur(4px)}
.del-modal{background:var(--sb);border:1px solid var(--bdr);border-radius:16px;padding:32px;max-width:420px;width:90%;text-align:center;animation:popIn .2s ease}
@keyframes popIn{from{transform:scale(.92);opacity:0}to{transform:scale(1);opacity:1}}
.del-modal h2{font-size:20px;font-weight:700;margin-bottom:10px}
.del-modal p{font-size:13px;color:var(--muted);line-height:1.65;margin-bottom:22px}
.del-modal-btns{display:flex;gap:10px;justify-content:center}
.del-confirm-btn{padding:10px 24px;border-radius:9px;background:var(--red);border:none;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.del-confirm-btn:hover{filter:brightness(1.15)}
.del-cancel-btn{padding:10px 24px;border-radius:9px;background:var(--surf2);border:1px solid var(--bdr);color:var(--muted);font-size:14px;font-weight:500;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.del-cancel-btn:hover{color:var(--txt)}
.passcode-input{width:100%;padding:14px 16px;border-radius:10px;background:var(--surf2);border:2px solid var(--bdr);color:var(--txt);font-size:18px;font-family:'JetBrains Mono',monospace;outline:none;text-align:center;letter-spacing:.15em;margin-bottom:14px;transition:border-color .2s}
.passcode-input:focus{border-color:var(--red)}
.toast.show{opacity:1!important;transform:translateY(0)!important}

/* ── ACHIEVEMENTS ── */
.ach-wrap{display:flex;height:100%;flex-direction:column;overflow:hidden;background:var(--bg)}
.ach-topbar{padding:14px 20px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.ach-body{flex:1;overflow-y:auto;padding:20px}
.ach-body::-webkit-scrollbar{width:4px}
.ach-body::-webkit-scrollbar-thumb{background:var(--surf3);border-radius:4px}
.ach-section-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:12px;margin-top:20px}
.ach-section-title:first-child{margin-top:0}
.ach-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:8px}
.ach-card{background:var(--sb);border:1px solid var(--bdr);border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:8px;transition:all .2s;position:relative;overflow:hidden}
.ach-card.unlocked{border-color:var(--accent);background:linear-gradient(135deg,var(--sb),rgba(124,106,255,.06))}
.ach-card.unlocked::after{content:'';position:absolute;top:0;right:0;width:0;height:0;border-left:28px solid transparent;border-top:28px solid var(--accent);opacity:.5}
.ach-card.locked{opacity:.5;filter:grayscale(.6)}
.ach-icon{font-size:28px;line-height:1}
.ach-name{font-size:13px;font-weight:600;color:var(--txt)}
.ach-desc{font-size:11px;color:var(--muted);line-height:1.5}
.ach-progress{height:4px;background:var(--surf2);border-radius:2px;overflow:hidden;margin-top:2px}
.ach-progress-bar{height:100%;border-radius:2px;background:var(--accent);transition:width .6s ease}
.ach-progress-label{font-size:10px;color:var(--hint);margin-top:3px}
.ach-unlocked-tag{font-size:10px;color:var(--accent);font-weight:600;margin-top:2px}
.ach-stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.ach-stat{background:var(--sb);border:1px solid var(--bdr);border-radius:10px;padding:14px;text-align:center}
.ach-stat-val{font-size:22px;font-weight:700;color:var(--accent);font-family:'JetBrains Mono',monospace}
.ach-stat-lbl{font-size:10px;color:var(--muted);margin-top:3px;text-transform:uppercase;letter-spacing:.04em}
/* Toast for achievement unlock */
.ach-toast{position:fixed;bottom:80px;right:24px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border-radius:12px;padding:12px 16px;display:flex;align-items:center;gap:10px;z-index:9997;transform:translateY(20px);opacity:0;transition:all .4s;pointer-events:none;max-width:280px;box-shadow:0 8px 24px rgba(0,0,0,.4)}
.ach-toast.show{transform:translateY(0);opacity:1}
.ach-toast-icon{font-size:22px;flex-shrink:0}
.ach-toast-body{flex:1}
.ach-toast-title{font-size:12px;font-weight:700;margin-bottom:2px}
.ach-toast-desc{font-size:11px;opacity:.85}

/* ── ONBOARDING ── */
#screen-onboard{width:100%;max-width:520px;display:none}
.onboard-card{background:var(--sb);border:1px solid var(--bdr);border-radius:16px;overflow:hidden}
.onboard-progress{display:flex;gap:4px;padding:16px 20px 0}
.onboard-step-dot{flex:1;height:3px;border-radius:2px;background:var(--surf2);transition:background .3s}
.onboard-step-dot.done{background:var(--accent)}
.onboard-step-dot.active{background:var(--accent);opacity:.6}
.onboard-body{padding:24px 22px}
.onboard-icon{font-size:40px;margin-bottom:14px;text-align:center}
.onboard-title{font-size:20px;font-weight:700;color:var(--txt);margin-bottom:6px;text-align:center}
.onboard-sub{font-size:13px;color:var(--muted);margin-bottom:22px;text-align:center;line-height:1.6}
.onboard-grid{display:grid;gap:8px;margin-bottom:20px}
.onboard-grid-2{grid-template-columns:1fr 1fr}
.onboard-grid-3{grid-template-columns:1fr 1fr 1fr}
.onboard-opt{padding:12px 10px;border-radius:10px;border:2px solid var(--bdr);background:var(--surf2);cursor:pointer;text-align:center;transition:all .18s;font-family:'Outfit',sans-serif}
.onboard-opt:hover{border-color:var(--accent);background:var(--surf3)}
.onboard-opt.selected{border-color:var(--accent);background:rgba(124,106,255,.1)}
.onboard-opt-icon{font-size:20px;margin-bottom:6px}
.onboard-opt-name{font-size:12px;font-weight:600;color:var(--txt)}
.onboard-opt-desc{font-size:10px;color:var(--muted);margin-top:2px}
.onboard-nav{display:flex;gap:10px;padding:0 0 4px}
.onboard-back{flex:1;padding:11px;border-radius:10px;background:transparent;border:1px solid var(--bdr);color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.onboard-back:hover{border-color:var(--bdr2);color:var(--txt)}
.onboard-next{flex:2;padding:11px;border-radius:10px;background:var(--accent);border:none;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.onboard-next:hover{background:var(--accent2)}
.onboard-skip{text-align:center;padding:10px 0 14px;font-size:11px;color:var(--hint);cursor:pointer;text-decoration:underline}
.onboard-skip:hover{color:var(--muted)}
/* Lang grid in onboarding */
.onboard-lang-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;max-height:260px;overflow-y:auto;margin-bottom:20px}
.onboard-lang-opt{padding:9px 12px;border-radius:8px;border:2px solid var(--bdr);background:var(--surf2);cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .15s;font-family:'Outfit',sans-serif}
.onboard-lang-opt:hover{border-color:var(--accent)}
.onboard-lang-opt.selected{border-color:var(--accent);background:rgba(124,106,255,.1)}
.onboard-lang-flag{font-size:18px;flex-shrink:0}
.onboard-lang-name{font-size:12px;font-weight:500;color:var(--txt)}
/* Theme preview cards */
.onboard-theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px}
.onboard-theme-card{border-radius:10px;border:2px solid var(--bdr);cursor:pointer;overflow:hidden;transition:all .18s}
.onboard-theme-card:hover,.onboard-theme-card.selected{border-color:var(--accent)}
.onboard-theme-preview{height:56px;display:flex;padding:8px;gap:6px;align-items:flex-start}
.onboard-theme-sb{width:20px;border-radius:4px;height:100%;flex-shrink:0}
.onboard-theme-msgs{flex:1;display:flex;flex-direction:column;gap:4px}
.onboard-theme-msg{border-radius:3px;height:7px}
.onboard-theme-name{font-size:11px;font-weight:500;padding:5px 8px;text-align:center}
/* Font preview */
.onboard-font-opt{padding:12px 14px;border-radius:10px;border:2px solid var(--bdr);background:var(--surf2);cursor:pointer;transition:all .15s}
.onboard-font-opt:hover,.onboard-font-opt.selected{border-color:var(--accent);background:rgba(124,106,255,.08)}
.onboard-font-preview{font-size:16px;font-weight:500;color:var(--txt);margin-bottom:3px}
.onboard-font-name{font-size:10px;color:var(--muted)}

/* ── LANDING PAGE ── */
#screen-landing{width:100%;max-width:420px;display:flex;flex-direction:column;align-items:center;gap:0}
.landing-card{background:var(--sb);border:1px solid var(--bdr);border-radius:20px;padding:36px 30px;width:100%;text-align:center}
.landing-logo{width:72px;height:72px;border-radius:20px;background:linear-gradient(135deg,var(--accent),#ec4899);display:flex;align-items:center;justify-content:center;font-size:34px;margin:0 auto 20px;box-shadow:0 8px 32px rgba(124,106,255,.35)}
.landing-title{font-size:26px;font-weight:700;color:var(--txt);margin-bottom:8px;letter-spacing:-.02em}
.landing-sub{font-size:13px;color:var(--muted);margin-bottom:28px;line-height:1.65}
.landing-features{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:28px;text-align:left}
.landing-feat{background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:8px}
.landing-feat-icon{font-size:18px;flex-shrink:0}
.landing-feat-text{font-size:11px;color:var(--muted);line-height:1.4}
.landing-btn-signup{width:100%;padding:13px;border-radius:12px;background:var(--accent);border:none;color:#fff;font-size:15px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;margin-bottom:10px;letter-spacing:.01em}
.landing-btn-signup:hover{background:var(--accent2);transform:translateY(-1px);box-shadow:0 6px 20px rgba(124,106,255,.3)}
.landing-btn-login{width:100%;padding:12px;border-radius:12px;background:transparent;border:1.5px solid var(--bdr);color:var(--txt);font-size:14px;font-weight:500;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.landing-btn-login:hover{border-color:var(--accent);color:var(--accent)}
.landing-divider{display:flex;align-items:center;gap:10px;margin:14px 0}
.landing-divider-line{flex:1;height:1px;background:var(--bdr)}
.landing-divider-text{font-size:11px;color:var(--hint)}
.landing-skip{font-size:11px;color:var(--hint);text-decoration:underline;cursor:pointer;margin-top:14px;background:none;border:none;font-family:'Outfit',sans-serif}
.landing-skip:hover{color:var(--muted)}
.landing-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#22c55e;border-radius:20px;padding:4px 10px;font-size:11px;font-weight:500;margin-bottom:20px}

/* ── CUSTOMIZE PROFILE ── */
.profile-opt{padding:8px 10px;border-radius:8px;border:2px solid var(--bdr);background:var(--surf2);cursor:pointer;font-size:12px;color:var(--muted);transition:all .15s;text-align:center}
.profile-opt:hover,.profile-opt.selected{border-color:var(--accent);color:var(--txt);background:rgba(124,106,255,.08)}
.profile-mod-btn{padding:5px 10px;border-radius:7px;border:1px solid var(--bdr);background:var(--surf2);color:var(--muted);font-size:11px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s}
.profile-mod-btn:hover,.profile-mod-btn.on{border-color:var(--accent);color:var(--accent);background:rgba(124,106,255,.1)}
.profile-color-dot{width:24px;height:24px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .15s;flex-shrink:0}
.profile-color-dot:hover,.profile-color-dot.selected{border-color:#fff;transform:scale(1.15)}
