function applyPfpEverywhere(dataURL, shape){
  const borderRadius = shape==='circle'?'50%':shape==='square'?'12px':'50%';
  ['sidebar-avatar','chat-sidebar-avatar','settings-av','acct-av','profile-av-preview'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el)return;
    el.innerHTML='';
    el.style.background=`url(${dataURL}) center/cover`;
    el.style.fontSize='0';
    el.style.borderRadius=borderRadius;
  });
}

function loadSavedProfileCustom(){
  const profile = safeLS('mega-profile-custom', {});
  if(profile.username && profile.usernameStyle){
    const inp=document.getElementById('profile-username-inp');
    if(inp) inp.value=profile.username;
    Object.assign(usernameState, profile.usernameStyle);
    applyUsernameStyle(profile.username, profile.usernameStyle);
  }
  if(profile.pfp){
    Object.assign(pfpState, profile.pfpState||{});
    applyPfpEverywhere(profile.pfp, pfpState.shape);
  }
}


