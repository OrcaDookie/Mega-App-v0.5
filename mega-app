let notesCurrentId=null;
function notesLoad(){return safeLS('mega-notes', []);}
function notesSaveAll(notes){localStorage.setItem('mega-notes',JSON.stringify(notes));}
function notesNew(){
  const notes=notesLoad();
  const note={id:Date.now(),title:'Untitled',body:'',updated:new Date().toISOString()};
  notes.unshift(note);notesSaveAll(notes);notesOpen(note.id);renderNotesList();
  setTimeout(()=>{const t=document.getElementById('note-title');if(t)t.focus();},50);
}
function notesOpen(id){
  notesCurrentId=id;const notes=notesLoad();const note=notes.find(n=>n.id===id);if(!note)return;
  const t=document.getElementById('note-title');const b=document.getElementById('note-body');
  if(t)t.value=note.title||'';if(b)b.innerHTML=note.body||'';
  notesUpdateFooter();renderNotesList();
}
function notesSave(){
  if(!notesCurrentId)return;const notes=notesLoad();const idx=notes.findIndex(n=>n.id===notesCurrentId);if(idx<0)return;
  const t=document.getElementById('note-title');const b=document.getElementById('note-body');
  notes[idx].title=t?t.value:'Untitled';notes[idx].body=b?b.innerHTML:'';notes[idx].updated=new Date().toISOString();
  notesSaveAll(notes);renderNotesList();notesUpdateFooter();
}
function notesDelete(){
  if(!notesCurrentId)return;if(!confirm('Delete this note?'))return;
  let notes=notesLoad().filter(n=>n.id!==notesCurrentId);notesSaveAll(notes);notesCurrentId=null;
  const t=document.getElementById('note-title');const b=document.getElementById('note-body');
  if(t)t.value='';if(b)b.value='';
  renderNotesList();if(notes&&notes.length)notesOpen(notes[0].id);notesUpdateFooter();
}
function renderNotesList(){
  var el=document.getElementById('notes-list');if(!el)return;
  var notes=notesLoad();
  if(!(notes&&notes.length)){el.innerHTML='<div style="padding:16px;font-size:12px;color:var(--hint);text-align:center">No notes yet. Hit + New to start!</div>';return;}
  el.innerHTML=notes.map(function(n){return '<div onclick="notesOpen('+n.id+')" style="padding:8px 10px;border-radius:8px;cursor:pointer;transition:all .15s;margin-bottom:2px;border-left:3px solid '+(n.id===notesCurrentId?'var(--accent)':'transparent')+';background:'+(n.id===notesCurrentId?'var(--surf2)':'transparent')+'" onmouseover="this.style.background=\'var(--surf2)\'" onmouseout="this.style.background=\''+(n.id===notesCurrentId?'var(--surf2)':'transparent')+'\'" ><div style="font-size:13px;font-weight:500;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">'+(n.title||'Untitled')+'</div><div style="font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px">'+((n.body||'').slice(0,50)||'No content')+'</div><div style="font-size:10px;color:var(--hint);margin-top:2px">'+new Date(n.updated).toLocaleDateString()+'</div></div>';}).join('');
  var cnt=document.getElementById('notes-count');if(cnt)cnt.textContent=(notes.length||0)+' note'+((notes.length||0)!==1?'s':'');
}
function notesUpdateFooter(){const body=document.getElementById('note-body');const el=document.getElementById('notes-chars');if(el)el.textContent=(body?(body&&body.value?body.value.length:0):0)+' chars';}
function initNotes(){
  let notes=notesLoad();
  if(!(notes&&notes.length)){const starters=[{id:1000001,title:'Welcome to Notes! 📝',body:'Create unlimited notes. Auto-saves as you type.',updated:new Date().toISOString()},{id:1000002,title:'Ideas 🚀',body:'',updated:new Date().toISOString()}];notesSaveAll(starters);notes=starters;}
  renderNotesList();if(notes&&notes.length)notesOpen(notes[0].id);
}


