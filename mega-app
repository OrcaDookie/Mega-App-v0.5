    if(jb){jb.onclick=nextJoke;}
  }

  // Toast
  const toast=document.getElementById('toast');
  if(toast){
    toast.textContent=(s.settingsLang||'Language')+': '+(btn?btn.textContent.trim():code);
    toast.classList.add('show');
    setTimeout(()=>toast.classList.remove('show'),2000);
  }
}

function loadLang(){
  const code = localStorage.getItem('lang') || 'en';
  const btn = document.getElementById('lng-'+code);
  applyLang(code, btn||document.getElementById('lng-en'));
}


