  const st2=(id,v)=>{const el=document.getElementById(id);if(el&&v)el.textContent=v;};
  st2('del1-no',s.del1No);st2('del1-yes',s.del1Yes);
  st2('del2-no',s.del2No);st2('del2-yes',s.del2Yes);
  st2('del3-cancel',s.del3Cancel);st2('del3-confirm',s.del3Confirm);

  // ── Welcome screen text ──
  document.querySelectorAll('.wlc .wt:not([style*="color:#"]),.special-wlc .wt:not([style*="color:"])').forEach(el=>{
    if(!el.style.color) el.textContent=s.welcomeTitle||el.textContent;
  });
  document.querySelectorAll('.wlc .ws,.special-wlc .ws').forEach(el=>{
    if(!el.closest('[id^="panel-abstract"],[id^="panel-void"],[id^="panel-dark"],[id^="panel-pure"],[id^="panel-fire"],[id^="panel-lava"]'))
