function renderPfpCanvas(){
  const canvas = document.getElementById('pfp-canvas');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0,0,W,H);

  // Resolve CSS vars
  const resolveCSSVar = (val) => {
    if(!val || !val.includes('var(')) return val;
    const root = document.documentElement;
    const computed = getComputedStyle(root);
    return val.replace(/var\(([^)]+)\)/g, (_, v) => computed.getPropertyValue(v.trim()).trim() || '#7c6aff');
  };

  const shape = pfpState.shape;
  ctx.save();

  // Clip to shape
  ctx.beginPath();
  if(shape === 'circle'){
    ctx.arc(W/2, H/2, W/2-3, 0, Math.PI*2);
  } else if(shape === 'square'){
    const r = 12;
    ctx.moveTo(r+3, 3); ctx.lineTo(W-r-3, 3);
    ctx.quadraticCurveTo(W-3,3,W-3,r+3);
    ctx.lineTo(W-3,H-r-3); ctx.quadraticCurveTo(W-3,H-3,W-r-3,H-3);
    ctx.lineTo(r+3,H-3); ctx.quadraticCurveTo(3,H-3,3,H-r-3);
    ctx.lineTo(3,r+3); ctx.quadraticCurveTo(3,3,r+3,3);
  } else if(shape === 'hex'){
    const cx=W/2, cy=H/2, r=W/2-4;
    for(let i=0;i<6;i++){
      const a = Math.PI/180*(60*i-30);
      i===0 ? ctx.moveTo(cx+r*Math.cos(a),cy+r*Math.sin(a)) : ctx.lineTo(cx+r*Math.cos(a),cy+r*Math.sin(a));
    }
    ctx.closePath();
  }
  ctx.clip();

  // Background
  const bg = resolveCSSVar(pfpState.bgColor);
  if(bg && bg.includes('gradient')){
    // parse gradient roughly
    const g = ctx.createLinearGradient(0,0,W,H);
    const colors = bg.match(/#[0-9a-f]{3,6}/gi) || ['#7c6aff','#ec4899'];
    g.addColorStop(0, colors[0]||'#7c6aff');
    g.addColorStop(1, colors[1]||'#ec4899');
    ctx.fillStyle = g;
  } else {
    ctx.fillStyle = bg || '#7c6aff';
  }
  ctx.fillRect(0,0,W,H);

  if(pfpState.type === 'image' && pfpState.imageData){
    const img = new Image();
    img.onload = () => {
      ctx.drawImage(img, 0, 0, W, H);
      ctx.restore();
      drawPfpBorder(ctx, W, H, shape, resolveCSSVar(pfpState.borderColor));
    };
    img.src = pfpState.imageData;
  } else {
    // Draw emoji
    const size = +document.getElementById('pfp-emoji-size')?.value || 40;
    ctx.font = `${size}px serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(pfpState.emoji, W/2, H/2+2);
    ctx.restore();
    drawPfpBorder(ctx, W, H, shape, resolveCSSVar(pfpState.borderColor));
  }
}

function drawPfpBorder(ctx, W, H, shape, color){
  if(!color || color === 'transparent') return;
  ctx.strokeStyle = color;
  ctx.lineWidth = 3;
  ctx.beginPath();
  if(shape === 'circle'){
    ctx.arc(W/2, H/2, W/2-2, 0, Math.PI*2);
  } else if(shape === 'square'){
    const r=12; ctx.moveTo(r+2,2); ctx.lineTo(W-r-2,2); ctx.quadraticCurveTo(W-2,2,W-2,r+2); ctx.lineTo(W-2,H-r-2); ctx.quadraticCurveTo(W-2,H-2,W-r-2,H-2); ctx.lineTo(r+2,H-2); ctx.quadraticCurveTo(2,H-2,2,H-r-2); ctx.lineTo(2,r+2); ctx.quadraticCurveTo(2,2,r+2,2);
  } else if(shape === 'hex'){
    const cx=W/2,cy=H/2,r=W/2-3; for(let i=0;i<6;i++){const a=Math.PI/180*(60*i-30);i===0?ctx.moveTo(cx+r*Math.cos(a),cy+r*Math.sin(a)):ctx.lineTo(cx+r*Math.cos(a),cy+r*Math.sin(a));}ctx.closePath();
  }
  ctx.stroke();
}

