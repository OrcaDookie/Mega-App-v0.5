.login-inp{width:100%;padding:10px 12px;border-radius:9px;background:var(--surf2);border:1px solid var(--bdr);color:var(--txt);font-size:13px;font-family:'Outfit',sans-serif;outline:none;transition:border-color .2s;box-sizing:border-box}
