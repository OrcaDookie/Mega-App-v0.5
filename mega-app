const WMO_CODES={0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',45:'Foggy',51:'Light drizzle',61:'Slight rain',63:'Moderate rain',71:'Slight snow',80:'Slight showers',95:'Thunderstorm'};
const WMO_ICON={0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',51:'🌦️',61:'🌧️',63:'🌧️',71:'🌨️',80:'🌦️',95:'⛈️'};
const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
async function fetchWeather(){
  const city=document.getElementById('weather-city-inp')?.value.trim();if(!city)return;
  setWeatherLoading('🔍 Searching for '+city+'...');
  try{const geoRes=await fetch(`https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=en&format=json`);const geoData=await geoRes.json();if(!geoData.results?.length){setWeatherErr('City not found.');return;}const loc=geoData.results[0];await fetchWeatherCoords(loc.latitude,loc.longitude,loc.name+', '+(loc.country||''));}
  catch(e){setWeatherErr('Could not fetch weather. Check your connection.');}
}
async function fetchWeatherByLocation(){
  if(!navigator.geolocation){setWeatherErr('Geolocation not supported.');return;}
  setWeatherLoading('📍 Getting your location...');
  navigator.geolocation.getCurrentPosition(async pos=>{try{const r=await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`);const d=await r.json();const city=d.address?.city||d.address?.town||'Your location';await fetchWeatherCoords(pos.coords.latitude,pos.coords.longitude,city);}catch(e){await fetchWeatherCoords(pos.coords.latitude,pos.coords.longitude,'Your location');}},()=>setWeatherErr('Location access denied.'));
}
async function fetchWeatherCoords(lat,lon,label){
  setWeatherLoading('⛅ Loading weather...');
  try{const url=`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m,surface_pressure,uv_index&daily=weather_code,temperature_2m_max,temperature_2m_min&wind_speed_unit=kmh&timezone=auto&forecast_days=10&past_days=3`;const res=await fetch(url);const d=await res.json();renderWeather(d,label);}
  catch(e){setWeatherErr('Weather data unavailable.');}
}
function renderWeather(d,label){
  var cur=d.current;var daily=d.daily;
  var code=cur.weather_code;
  var icon=WMO_ICON[code]||'🌡️';
  var desc=WMO_CODES[code]||'Unknown';
  var temp=Math.round(cur.temperature_2m);
  var feels=Math.round(cur.apparent_temperature);
  var humidity=cur.relative_humidity_2m;
  var wind=Math.round(cur.wind_speed_10m);
  var pressure=cur.surface_pressure?Math.round(cur.surface_pressure):null;
  var uv=cur.uv_index!=null?parseFloat(cur.uv_index):null;
  var uvLabel=uv==null?'N/A':uv<3?'Low':uv<6?'Moderate':uv<8?'High':uv<11?'Very High':'Extreme';
  var uvColor=uv==null?'var(--muted)':uv<3?'#22c55e':uv<6?'#f59e0b':uv<8?'#f97316':uv<11?'#ef4444':'#a855f7';

  // Build forecast - past days first, then future
  var forecastHTML='';
  var today=new Date();
  for(var i=0;i<(daily.time&&daily.time.length||0);i++){
    var dt=new Date(daily.time[i]);
    var isPast=dt<today&&dt.toDateString()!==today.toDateString();
    var isToday=dt.toDateString()===today.toDateString();
    var fc=daily.weather_code[i];
    var hi=Math.round(daily.temperature_2m_max[i]);
    var lo=Math.round(daily.temperature_2m_min[i]);
    var dayLabel=isToday?'Today':isPast?'-'+(Math.round((today-dt)/86400000))+'d':i===0?'Today':dt.toLocaleDateString('en',{weekday:'short'});
    forecastHTML+='<div style="background:var(--sb);border:1px solid var(--bdr);border-radius:10px;padding:10px 6px;text-align:center;opacity:'+(isPast?'0.6':'1')+'">'
      +'<div style="font-size:11px;color:var(--muted);font-weight:600">'+dayLabel+'</div>'
      +'<div style="font-size:22px;margin:4px 0">'+(WMO_ICON[fc]||'🌡️')+'</div>'
      +'<div style="font-size:13px;font-weight:700;color:var(--txt)">'+hi+'°</div>'
      +'<div style="font-size:11px;color:var(--muted)">'+lo+'°</div>'
      +(isPast?'<div style="font-size:9px;color:var(--hint);margin-top:2px">past</div>':'')
      +'</div>';
  }

  var el=document.getElementById('weather-output');
  if(!el)return;
  el.innerHTML=
    '<div style="background:var(--sb);border:1px solid var(--bdr);border-radius:16px;padding:24px;margin-bottom:14px;position:relative;overflow:hidden">'
      +'<div style="position:absolute;right:-10px;top:-10px;font-size:100px;opacity:.07">'+icon+'</div>'
      +'<div style="font-size:13px;color:var(--muted);margin-bottom:6px">📍 '+label+'</div>'
      +'<div style="font-size:56px;font-weight:700;color:var(--txt);letter-spacing:-.03em;line-height:1">'+temp+'°<span style="font-size:24px;font-weight:400;color:var(--muted)">C</span></div>'
      +'<div style="font-size:16px;color:var(--muted);margin-top:4px">'+desc+'</div>'
      +'<div style="font-size:12px;color:var(--hint)">Feels like '+feels+'°C</div>'
    +'</div>'
    +'<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px">'
      +'<div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:12px;text-align:center"><div style="font-size:20px;margin-bottom:4px">💧</div><div style="font-size:15px;font-weight:600;color:var(--txt)">'+humidity+'%</div><div style="font-size:10px;color:var(--muted);text-transform:uppercase">Humidity</div></div>'
      +'<div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:12px;text-align:center"><div style="font-size:20px;margin-bottom:4px">💨</div><div style="font-size:15px;font-weight:600;color:var(--txt)">'+wind+' km/h</div><div style="font-size:10px;color:var(--muted);text-transform:uppercase">Wind</div></div>'
      +(pressure?'<div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:12px;text-align:center"><div style="font-size:20px;margin-bottom:4px">🌡️</div><div style="font-size:15px;font-weight:600;color:var(--txt)">'+pressure+' hPa</div><div style="font-size:10px;color:var(--muted);text-transform:uppercase">Pressure</div></div>':'')
      +(uv!=null?'<div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:10px;padding:12px;text-align:center"><div style="font-size:20px;margin-bottom:4px">☀️</div><div style="font-size:15px;font-weight:600;color:'+uvColor+'">'+uv.toFixed(1)+' <span style="font-size:11px">'+uvLabel+'</span></div><div style="font-size:10px;color:var(--muted);text-transform:uppercase">UV Index</div></div>':'')
    +'</div>'
    +'<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(70px,1fr));gap:8px">'+forecastHTML+'</div>';
}
