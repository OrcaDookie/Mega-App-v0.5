// ACCOUNT MANAGEMENT (change username, password, delete)
// ════════════════════════════════════════
function refreshAccountSettings(){
  if(!currentUser||currentUser.id==='guest'){
    (document.getElementById('acct-settings-main')||{style:{}}).style.display='none';
    (document.getElementById('acct-settings-guest')||{style:{}}).style.display='block';
    return;
  }
  (document.getElementById('acct-settings-main')||{style:{}}).style.display='block';
  (document.getElementById('acct-settings-guest')||{style:{}}).style.display='none';
  (document.getElementById('settings-username')||{}).textContent=currentUser.username;
  (document.getElementById('settings-email')||{}).textContent=currentUser.email||'No email set';
  (document.getElementById('settings-av')||{}).textContent=currentUser.username[0].toUpperCase();
}

function changeUsername(){
  if(!currentUser||currentUser.id==='guest')return;
  const newName=document.getElementById('new-username-inp').value.trim();
  const msg=document.getElementById('username-msg');
  if(!newName){msg.textContent='Type a new username first!';msg.style.color='var(--red)';msg.style.display='block';return;}
  const users=getUsers();
  if(Object.values(users).find(u=>u.username===newName&&u.id!==currentUser.id)){
    msg.textContent='That username is already taken!';msg.style.color='var(--red)';msg.style.display='block';return;
  }
  users[currentUser.id].username=newName;
  saveUsers(users);
  currentUser.username=newName;
  localStorage.setItem('mega-session',JSON.stringify(currentUser));
  refreshAccountSettings();
  document.querySelector('.av.u').textContent=newName[0].toUpperCase();
  (document.getElementById('acct-name')||{}).textContent=newName;
  document.getElementById('active-model') && (document.querySelector('.chat-logo-txt').textContent=localStorage.getItem('appName')||'Local AI');
  msg.textContent='Username updated! Nice new name 😎';msg.style.color='var(--green)';msg.style.display='block';
  (document.getElementById('new-username-inp')||{}).value='';
  setTimeout(()=>msg.style.display='none',3000);
}

function changePassword(){
  if(!currentUser||currentUser.id==='guest')return;
  const curr=document.getElementById('curr-pass-inp').value;
  const newp=document.getElementById('new-pass-inp').value;
  const msg=document.getElementById('pass-msg');
  const users=getUsers();
  const user=users[currentUser.id];
  if(!user||user.password!==btoa(curr)){
    msg.textContent='Current password is wrong. Did your fingers slip? 😄';msg.style.color='var(--red)';msg.style.display='block';return;
  }
  if((newp||'').length<4){
    msg.textContent='New password needs at least 4 characters!';msg.style.color='var(--red)';msg.style.display='block';return;
  }
  users[currentUser.id].password=btoa(newp);
  saveUsers(users);
  currentUser.password=btoa(newp);
  localStorage.setItem('mega-session',JSON.stringify(currentUser));
  (document.getElementById('curr-pass-inp')||{}).value='';
  (document.getElementById('new-pass-inp')||{}).value='';
  msg.textContent='Password changed! Do not forget it this time 🔐';msg.style.color='var(--green)';msg.style.display='block';
  setTimeout(()=>msg.style.display='none',3000);
}

// ── DELETE ACCOUNT FLOW ──
function startDeleteAccount(){
  if(!currentUser||currentUser.id==='guest'){alert('No account to delete, ghost! 👻');return;}
  delStep(1);
  (document.getElementById('del-overlay')||{style:{}}).style.display='flex';
}

function closeDel(){
  (document.getElementById('del-overlay')||{style:{}}).style.display='none';
  (document.getElementById('del-passcode')||{}).value='';
  (document.getElementById('del-pass-err')||{style:{}}).style.display='none';
}

function delStep(n){
  [1,2,3].forEach(i=>{
    const el=document.getElementById('del-step-'+i);
    if(el) el.style.display=i===n?'block':'none';
  });
  if(n===3) setTimeout(()=>document.getElementById('del-passcode').focus(),100);
}

function confirmDeleteAccount(){
  if(!currentUser||currentUser.id==='guest')return;
  const entered=document.getElementById('del-passcode').value;
  const users=getUsers();
  const user=users[currentUser.id];
  if(!user||user.password!==btoa(entered)){
    (document.getElementById('del-pass-err')||{style:{}}).style.display='block';
    (document.getElementById('del-passcode')||{}).value='';
    document.getElementById('del-passcode').focus();
    return;
  }
  // Delete the account
  delete users[currentUser.id];
  saveUsers(users);
  localStorage.removeItem('mega-session');
  closeDel();
  currentUser=null;
  // Sign out and go back to login
  
  
  
  (document.getElementById('chat-setup')||{style:{}}).style.display='flex';
  (document.getElementById('chat-app')||{style:{}}).style.display='none';
  // Little farewell joke
  (document.getElementById('joke-text')||{}).textContent='Account deleted. The AI is sobbing. Just kidding. Maybe. Welcome back, stranger.';
  (document.getElementById('joke-emoji')||{}).textContent='😢';
}


