  applyUsernameStyle(text, usernameState);

  const msg=document.getElementById('username-msg');
  if(msg){msg.textContent='Username applied! ✓';msg.style.color='var(--green)';msg.style.display='block';setTimeout(()=>msg.style.display='none',2500);}
