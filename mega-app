function getWaterStreak(){
  try{
    var data=JSON.parse(localStorage.getItem('mega-water-streak')||'{"streak":0,"lastDate":""}');
    var today=new Date().toDateString();
    var yesterday=new Date(Date.now()-86400000).toDateString();
    if(data.lastDate===today||data.lastDate===yesterday) return data.streak||0;
    return 0;
  }catch(e){return 0;}
}
function updateWaterStreak(){
  try{
    var today=new Date().toDateString();
    var data=JSON.parse(localStorage.getItem('mega-water-streak')||'{"streak":0,"lastDate":""}');
    var yesterday=new Date(Date.now()-86400000).toDateString();
    if(data.lastDate===today) return;
    var newStreak=(data.lastDate===yesterday)?data.streak+1:1;
    localStorage.setItem('mega-water-streak',JSON.stringify({streak:newStreak,lastDate:today}));
  }catch(e){}
}
function renderWaterStreak(){
  var el=document.getElementById('water-streak');if(!el)return;
  var s=getWaterStreak();
  el.textContent=s+' day streak'+(s!==1?'s':'');
  el.style.color=s>=7?'#f59e0b':s>=3?'#22c55e':'var(--muted)';
}


