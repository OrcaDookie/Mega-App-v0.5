function chatSysPrompt(){
  const vm=VIRTUAL_MODELS[currentModel];
  let s=vm?vm.systemPrompt:'You are a helpful, smart, friendly AI assistant. Use markdown formatting — bold, code blocks, bullet points, headers — to make responses clear.';
  if(document.getElementById('t-c').classList.contains('on'))s+=' Be SHORT and direct.';
  if(document.getElementById('t-d').classList.contains('on'))s+=' Think step by step.';
  if(document.getElementById('t-co').classList.contains('on'))s+=' Include complete working code examples.';
  if(document.getElementById('t-ar').classList.contains('on'))s+=' Respond in Arabic.';
  if(document.getElementById('t-fr').classList.contains('on'))s+=' Respond in French.';
  if(window._langSuffix&&!document.getElementById('t-ar').classList.contains('on')&&!document.getElementById('t-fr').classList.contains('on'))s+=window._langSuffix||'';
  return s;
}

async function chatSend(){
  if(busy)return;
  const inp=document.getElementById('inp');
  const text=inp.value.trim();if(!text)return;
  lastTxt=text;inp.value='';inp.style.height='auto';
  busy=true;document.getElementById('sbtn').disabled=true;
  addUserMsg(text);chatMsgs.push({role:'user',content:text});
  trackMessage(null);
  await callOllama();
}

async function callOllama(){
  showTyping();
  try{
    const vm=VIRTUAL_MODELS[currentModel];
    const realModel=vm?(document.getElementById('model-sel').dataset.bestModel||'mistral'):currentModel;
    const res=await fetch('/ollama/api/chat',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:realModel,messages:[{role:'system',content:chatSysPrompt()},...chatMsgs],stream:false})
    });
    if(!res.ok)throw new Error('HTTP '+res.status);
    const data=await res.json();
    rmTyping();
    const reply=data?.message?.content||'No response.';
    chatMsgs.push({role:'assistant',content:reply});
    const el=addAIMsg();el.innerHTML=mdRender(reply);
    updateChatSB(lastTxt);
  }catch(e){
    rmTyping();
    const el=addAIMsg();
    el.innerHTML=`<p style="color:var(--red)"><strong>Cannot connect to Ollama.</strong><br><br>Make sure Ollama is running and you pulled the model:<br><code style="background:var(--code);padding:2px 6px;border-radius:4px;font-family:monospace">ollama pull ${currentModel}</code><br><br>
    <button onclick="regenChat()" style="padding:6px 12px;border-radius:7px;background:var(--accent);border:none;color:#fff;cursor:pointer;font-family:'Outfit',sans-serif;font-size:12px;margin-top:6px">Retry</button>
    <button onclick="(document.getElementById('chat-setup')||{style:{}}).style.display='flex';(document.getElementById('chat-app')||{style:{}}).style.display='none'" style="margin-left:6px;padding:6px 12px;border-radius:7px;background:transparent;border:1px solid var(--bdr);color:var(--muted);cursor:pointer;font-family:'Outfit',sans-serif;font-size:12px">Setup</button></p>`;
  }
  busy=false;document.getElementById('sbtn').disabled=false;
  document.getElementById('inp').focus();chatScroll();
}

function updateChatSB(text){
  const s=document.querySelector('#cl .ci.on span:last-child');
  if(s&&s.textContent==='New conversation')s.textContent=text.slice(0,24)+(text.length>24?'…':'');
}

function newChat(){
