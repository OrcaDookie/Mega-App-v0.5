    </div>
    <div class="calc-main">
      <div class="calc-display">
        <div class="calc-expr" id="calc-expr"></div>
        <div class="calc-result" id="calc-result">0</div>
        <div class="calc-sub" id="calc-sub"></div>
      </div>
      <div class="calc-grid" id="calc-grid"></div>
    </div>
  </div>
</div>
