let jokeIdx = Math.floor(Math.random()*((JOKES&&JOKES.length)||1));

function showJoke(){
  const j = JOKES[jokeIdx];
  const box = document.getElementById('joke-box');
  const em = document.getElementById('joke-emoji');
  const tx = document.getElementById('joke-text');
  if(!box||!em||!tx) return;
  // fade out
  box.style.opacity='0';
  box.style.transform='translateY(4px)';
  setTimeout(()=>{
    em.textContent = j.e;
    tx.textContent = j.t;
    box.style.opacity='1';
    box.style.transform='translateY(0)';
  }, 150);
  box.style.transition='opacity .15s ease, transform .15s ease';
}

function nextJoke(){
  jokeIdx = (jokeIdx+1)%((JOKES&&JOKES.length)||1);
  showJoke();
  initPfpEmojiGrid();
  renderPfpCanvas();
  loadSavedProfileCustom();
}


