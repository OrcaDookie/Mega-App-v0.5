// Stats storage
function getAchStats(){
  var def={messages:0,chats:0,aisUsed:[],panelsUsed:[],account:false,theme:false,lang:false,secrets:[]};
  try{
    var raw=localStorage.getItem('ach-stats');
    if(!raw) return JSON.parse(JSON.stringify(def));
    var p=JSON.parse(raw)||{};
    return {
      messages:  typeof p.messages==='number'  ? p.messages  : 0,
      chats:     typeof p.chats==='number'     ? p.chats     : 0,
      aisUsed:   Array.isArray(p.aisUsed)      ? p.aisUsed   : [],
      panelsUsed:Array.isArray(p.panelsUsed)   ? p.panelsUsed: [],
      account:!!p.account, theme:!!p.theme, lang:!!p.lang,
      secrets:   Array.isArray(p.secrets)      ? p.secrets   : []
    };
  }catch(e){ return JSON.parse(JSON.stringify(def)); }
}
function saveAchStats(s){ localStorage.setItem('ach-stats',JSON.stringify(s)); }
function getUnlocked(){ try{ const r=safeLS('ach-unlocked', []); return Array.isArray(r)?r:[]; }catch(e){ return []; } }
function saveUnlocked(u){ localStorage.setItem('ach-unlocked',JSON.stringify(u)); }

function checkAchievements(stats){
  const unlocked = getUnlocked();
  const newlyUnlocked = [];

  ACHIEVEMENTS.forEach(a => {
    if(unlocked.includes(a.id)) return;
    let earned = false;
    const r = a.req;
    if(r.type==='messages' && stats.messages >= r.n) earned=true;
    if(r.type==='chats' && stats.chats >= r.n) earned=true;
    if(r.type==='ai' && stats.aisUsed.includes(r.ai)) earned=true;
    if(r.type==='all_ais' && ['abstract','void','dark','pure','fire','lava','sun','golden','electric','cure'].every(ai=>stats.aisUsed.includes(ai))) earned=true;
    if(r.type==='panel' && stats.panelsUsed.includes(r.panel)) earned=true;
    if(r.type==='all_tools' && ['calc','color','code'].every(p=>stats.panelsUsed.includes(p))) earned=true;
    if(r.type==='account' && stats.account) earned=true;
    if(r.type==='theme' && stats.theme) earned=true;
    if(r.type==='lang' && stats.lang) earned=true;
    if(r.type==='secret' && stats.secrets.includes(r.key)) earned=true;
    if(r.type==='time'){
      const h = new Date().getHours();
      if(r.hour===0 && (h>=0&&h<4)) earned=true;
      if(r.hour===5 && (h>=4&&h<6)) earned=true;
    }
    if(earned){
      unlocked.push(a.id);
      newlyUnlocked.push(a);
    }
  });

  if((newlyUnlocked||[]).length>0){
    saveUnlocked(unlocked);
    // Show toast for each (with delay)
    newlyUnlocked.forEach((a,i) => {
      setTimeout(()=>showAchToast(a), i*2500);
    });
    // Refresh panel if open
    renderAchievements();
  }
}

function showAchToast(a){
  const t = document.getElementById('ach-toast');
  const ic = document.getElementById('ach-toast-icon');
  const desc = document.getElementById('ach-toast-desc');
  if(!t) return;
  ic.innerHTML = ACH_SVG[a.id] || a.icon;
  desc.textContent = a.name + ' — ' + a.desc;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 3500);
}

